function startRound(){
  clearTimeout(npcTimer);
  resetFighters();
  layoutUI();
  roundTimer=ROUND_TIME;
  document.getElementById('timer').textContent=roundTimer;
  document.getElementById('rlbl').textContent='ROUND '+roundNum;
  document.getElementById('timer').style.color='#fff';
  document.getElementById('pz').style.display='flex';
  document.getElementById('pz').style.flexDirection='column';
  particles=[];hitEffects=[];
  buildBg();
  gameRunning=false;pLock=true;
  announce('ROUND '+roundNum,'',700);
  setTimeout(()=>{
    announce('¡RESUELVE!','PRIMERO EN RESOLVER ATACA',950);
    setTimeout(()=>{
      gameRunning=true;pLock=false;newPuzzle();
      timerInt=setInterval(tickTimer,1000);
    },1100);
  },950);
}

function tickTimer(){
  roundTimer--;
  document.getElementById('timer').textContent=roundTimer;
  if(roundTimer<=10)document.getElementById('timer').style.color='#ff4400';
  if(roundTimer<=0){clearInterval(timerInt);gameRunning=false;timeUp();}
}
function timeUp(){const w=f1.hp>=f2.hp?1:2;endRound(w,'TIME UP!');}

function endRound(winner,reason){
  clearInterval(timerInt);gameRunning=false;pLock=true;
  document.getElementById('pz').style.display='none';
  const wf=winner===1?f1:f2;wf.state='win';
  announce(reason,'PLAYER '+winner+' WINS!',1300);
  spawnBurst(wf.x,wf.y-80,wf.color,18);
  if(winner===1)p1Wins++;else p2Wins++;
  updateStocks();
  const need=Math.ceil(TOTAL_ROUNDS/2)+1;
  setTimeout(()=>{
    if(p1Wins>=need||p2Wins>=need)showResult(winner);
    else{roundNum++;document.getElementById('pz').style.display='flex';startRound();}
  },2700);
}

function updateStocks(){
  document.getElementById('st1').querySelectorAll('.sd').forEach((d,i)=>d.classList.toggle('on',i<3-p2Wins));
  document.getElementById('st2').querySelectorAll('.sd').forEach((d,i)=>d.classList.toggle('on',i<3-p1Wins));
}
function showResult(w){
  const wf=w===1?f1:f2;
  document.getElementById('rtitle').textContent=wf.name+' WINS!';
  document.getElementById('rtitle').style.color=wf.color;
  document.getElementById('rtitle').style.textShadow=`0 0 28px ${wf.color}`;
  document.getElementById('rsub').textContent='PLAYER '+w+' ES EL BRAIN CHAMPION!';
  document.getElementById('result').style.display='flex';
}
function restartGame(){
  document.getElementById('result').style.display='none';
  document.getElementById('pz').style.display='flex';
  p1Wins=0;p2Wins=0;roundNum=1;roundTimer=ROUND_TIME;
  document.getElementById('timer').style.color='#fff';
  updateStocks();startRound();
}
function updateHUD(){
  if(!f1||!f2)return;
  document.getElementById('hp1').style.width=(f1.hp/MAX_HP*100)+'%';
  document.getElementById('hp2').style.width=(f2.hp/MAX_HP*100)+'%';
  document.getElementById('pw1').style.width=(f1.power/MAX_POW*100)+'%';
  document.getElementById('pw2').style.width=(f2.power/MAX_POW*100)+'%';
}
function announce(main,sub,dur){
  const am=document.getElementById('amain'),as=document.getElementById('asub');
  am.textContent=main;as.textContent=sub;am.style.opacity=1;as.style.opacity=1;
  am.style.color=main==='¡RESUELVE!'?'#ffff00':main.includes('K.O')?'#ff2200':'#fff';
  clearTimeout(am._t);am._t=setTimeout(()=>{am.style.opacity=0;as.style.opacity=0;},dur);
}
function showHit(text,color,dmg){
  const ht=document.getElementById('httx'),dt=document.getElementById('dmtx');
  ht.textContent=text;ht.style.color=color;ht.style.opacity=1;
  dt.textContent=dmg+' DMG';dt.style.opacity=1;
  clearTimeout(ht._t);ht._t=setTimeout(()=>{ht.style.opacity=0;dt.style.opacity=0;},900);
}

// ══════════════════════════════════════════════════════════
// BACKGROUND
// ══════════════════════════════════════════════════════════
function buildBg(){
  bgCanvas=document.createElement('canvas');bgCanvas.width=W;bgCanvas.height=H;
  const c=bgCanvas.getContext('2d');
  const sky=c.createLinearGradient(0,0,0,H);
  sky.addColorStop(0,'#020010');sky.addColorStop(.55,'#080020');sky.addColorStop(1,'#120030');
  c.fillStyle=sky;c.fillRect(0,0,W,H);
  // Neural net bg
  c.strokeStyle='rgba(100,0,200,0.07)';c.lineWidth=1;
  const nds=Array.from({length:20},()=>({x:Math.random()*W,y:Math.random()*H*.7}));
  nds.forEach(n=>nds.forEach(m=>{
    const d=Math.hypot(n.x-m.x,n.y-m.y);
    if(d<W*.22){c.globalAlpha=.04*(1-d/(W*.22));c.beginPath();c.moveTo(n.x,n.y);c.lineTo(m.x,m.y);c.stroke();}
  }));
  c.globalAlpha=1;
  // City
  c.fillStyle='rgba(8,3,18,.95)';
  for(let i=0;i<16;i++){const bx=i*(W/16),bw=W/16+8,bh=50+Math.random()*130;c.fillRect(bx,H*.55-bh,bw,bh+H*.45);}
  // Window lights
  c.save();for(let i=0;i<50;i++){const wx=Math.random()*W,wy=H*.1+Math.random()*H*.4;const wc=['#ff44aa','#4488ff','#44ffcc','#ffaa00','#cc44ff'][Math.floor(Math.random()*5)];c.fillStyle=wc;c.shadowColor=wc;c.shadowBlur=5;c.fillRect(wx,wy,3+Math.random()*5,4+Math.random()*7);}c.restore();
  // Ground
  const grd=c.createLinearGradient(0,H*FLOOR_R,0,H);grd.addColorStop(0,'#180830');grd.addColorStop(1,'#060410');
  c.fillStyle=grd;c.fillRect(0,H*FLOOR_R,W,H*(1-FLOOR_R));
  c.save();c.strokeStyle='#7700cc';c.lineWidth=2;c.shadowColor='#aa44ff';c.shadowBlur=16;c.beginPath();c.moveTo(0,H*FLOOR_R);c.lineTo(W,H*FLOOR_R);c.stroke();c.restore();
  // Floor grid
  c.save();c.strokeStyle='rgba(90,0,180,0.1)';c.lineWidth=1;
  for(let i=0;i<W;i+=55){c.beginPath();c.moveTo(i,H*FLOOR_R);c.lineTo(W/2+(i-W/2)*3.5,H);c.stroke();}
  for(let j=1;j<6;j++){const y=H*FLOOR_R+(H-H*FLOOR_R)*j/6;c.beginPath();c.moveTo(0,y);c.lineTo(W,y);c.stroke();}
  c.restore();
  // Stage pillars
  [[W*.06,H*FLOOR_R],[W*.94,H*FLOOR_R]].forEach(([px,py])=>{
    c.save();c.strokeStyle='#5500aa';c.lineWidth=3;c.shadowColor='#8800ff';c.shadowBlur=14;c.beginPath();c.moveTo(px,py);c.lineTo(px,py-140);c.stroke();c.fillStyle='rgba(170,68,255,.9)';c.beginPath();c.arc(px,py-140,7,0,Math.PI*2);c.fill();c.restore();
  });
  // Math symbols float
  const syms=['∑','π','∞','Ψ','Ω','λ','∂','∇'];c.font='15px serif';
  for(let i=0;i<10;i++){c.globalAlpha=.05+Math.random()*.07;c.fillStyle='#aa44ff';c.fillText(syms[Math.floor(Math.random()*syms.length)],Math.random()*W,H*.1+Math.random()*H*.55);}
  c.globalAlpha=1;
  // bg particles
  bgParts=Array.from({length:28},()=>({x:Math.random()*W,y:Math.random()*H*.6,
    vx:(Math.random()-.5)*14,vy:-7-Math.random()*20,sz:1+Math.random()*2,
    life:1+Math.random()*3,ml:4,
    col:['#8844ff','#4488ff','#ff44cc','#44ffcc'][Math.floor(Math.random()*4)]}));
}

// ══════════════════════════════════════════════════════════
// PARTICLES
// ══════════════════════════════════════════════════════════
function spawnBurst(x,y,col,n=10){
  for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,s=80+Math.random()*200;
    particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-80,life:.5+Math.random()*.4,ml:.9,sz:3+Math.random()*4,col});}
}
function spawnFx(x,y,txt,col,sc=1){hitEffects.push({x,y,txt,col,sc,life:1.3,vy:-75});}
function updParts(dt){
  for(let i=particles.length-1;i>=0;i--){const p=particles[i];p.x+=p.vx*dt;p.y+=p.vy*dt;p.vy+=240*dt;p.vx*=.91;p.life-=dt;if(p.life<=0)particles.splice(i,1);}
  for(let i=hitEffects.length-1;i>=0;i--){const e=hitEffects[i];e.y+=e.vy*dt;e.vy*=.87;e.life-=dt;if(e.life<=0)hitEffects.splice(i,1);}
  bgParts.forEach(p=>{p.x+=p.vx*dt;p.y+=p.vy*dt;p.life-=dt;if(p.life<=0){p.x=Math.random()*W;p.y=H*FLOOR_R;p.life=p.ml;p.vy=-7-Math.random()*20;}});
}
function drawParts(){
  particles.forEach(p=>{const a=p.life/p.ml;ctx.save();ctx.globalAlpha=a;ctx.fillStyle=p.col;ctx.shadowColor=p.col;ctx.shadowBlur=7;ctx.beginPath();ctx.arc(p.x,p.y,p.sz*a,0,Math.PI*2);ctx.fill();ctx.restore();});
  hitEffects.forEach(e=>{const a=Math.min(1,e.life*1.4);ctx.save();ctx.globalAlpha=a;ctx.font=`bold ${Math.floor(16*e.sc)}px 'Courier New'`;ctx.fillStyle=e.col;ctx.shadowColor=e.col;ctx.shadowBlur=12;ctx.textAlign='center';ctx.fillText(e.txt,e.x,e.y);ctx.restore();});
  bgParts.forEach(p=>{const a=p.life/p.ml*.45;ctx.save();ctx.globalAlpha=a;ctx.fillStyle=p.col;ctx.shadowColor=p.col;ctx.shadowBlur=5;ctx.beginPath();ctx.arc(p.x,p.y,p.sz,0,Math.PI*2);ctx.fill();ctx.restore();});
}

// ══════════════════════════════════════════════════════════
// DRAW FIGHTER
// ══════════════════════════════════════════════════════════
function drawFighter(f,t){
  const x=f.x,y=f.y,fc=f.facing;
  const w=46,h=90;
  ctx.save();ctx.translate(x,y);ctx.scale(fc,1);
  // Shadow
  ctx.fillStyle='rgba(0,0,0,.3)';ctx.beginPath();ctx.ellipse(0,2,w*.5,6,0,0,Math.PI*2);ctx.fill();
  const fl=f.state==='hurt'&&(Math.floor(f.stateT*14)%2===0);
  const sg=f.state==='super';const win=f.state==='win';
  ctx.shadowColor=sg?f.def.super.color:f.color;ctx.shadowBlur=sg?38:win?22:10;
  const col=fl?'#fff':sg?f.def.super.color:f.color;
  const bob=win?Math.sin(t*6)*5:(f.state==='idle'?Math.sin(t*2.5+f.slot)*2.5:0);
  function dk(hex,fac){const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return `rgb(${Math.floor(r*fac)},${Math.floor(g*fac)},${Math.floor(b*fac)})`;}
  // Legs
  ctx.fillStyle=fl?'#fff':dk(f.color,.55);
  ctx.fillRect(-w*.26,(-h*.4)+bob,w*.18,h*.42);ctx.fillRect(w*.08,(-h*.4)+bob,w*.18,h*.42);
  // Torso
  ctx.fillStyle=col;ctx.fillRect(-w*.32,(-h*.8)+bob,w*.64,h*.4);
  // Attack arm
  if(f.state==='attack'){ctx.fillStyle='#fff';ctx.shadowBlur=20;ctx.fillRect(w*.3+bob,(-h*.65)+bob,w*.5,w*.18);ctx.fillStyle=f.color;ctx.shadowBlur=26;ctx.beginPath();ctx.arc(w*.3+w*.5+bob,(-h*.65+w*.09)+bob,w*.13,0,Math.PI*2);ctx.fill();}
  else if(win){ctx.fillStyle=col;ctx.fillRect(w*.28,(-h*1.05)+bob,w*.13,h*.35);}
  else{ctx.fillStyle=col;ctx.fillRect(w*.3,(-h*.76)+bob,w*.12,h*.28);}
  ctx.fillStyle=dk(f.color,.5);ctx.fillRect(-w*.42,(-h*.76)+bob,w*.12,h*.28);
  // Head
  ctx.fillStyle=col;ctx.shadowBlur=12;ctx.beginPath();ctx.arc(0,(-h*.86)+bob,w*.24,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#fff';ctx.shadowBlur=5;ctx.beginPath();ctx.arc(w*.06,(-h*.88)+bob,4,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#000';ctx.shadowBlur=0;ctx.beginPath();ctx.arc(w*.09,(-h*.88)+bob,2.2,0,Math.PI*2);ctx.fill();
  // Char detail
  switch(f.cid){
    case 0:ctx.fillStyle='#ff8800';ctx.shadowColor='#ff4400';ctx.shadowBlur=14;for(let i=0;i<3;i++){const a=(-Math.PI*.35)+i*.28+Math.sin(t*5+i)*.18;ctx.beginPath();ctx.moveTo(0,(-h*.86)+bob);ctx.lineTo(Math.cos(a-Math.PI/2)*16,(-h*.86)-14+bob+Math.sin(t*6+i)*3);ctx.lineTo(Math.cos(a-Math.PI/2)*6,(-h*.86)-6+bob);ctx.closePath();ctx.fill();}break;
    case 1:ctx.strokeStyle='#88eeff';ctx.lineWidth=2;ctx.shadowColor='#00aaff';ctx.shadowBlur=12;ctx.beginPath();ctx.moveTo(-w*.08,(-h*.92)+bob);ctx.lineTo(w*.12,(-h*.99)+bob);ctx.lineTo(-w*.04,(-h*1.05)+bob);ctx.stroke();break;
    case 2:ctx.globalAlpha=.3+Math.sin(t*4)*.18;ctx.strokeStyle='#00ffcc';ctx.lineWidth=2;ctx.shadowColor='#00ffcc';ctx.shadowBlur=16;ctx.beginPath();ctx.arc(0,(-h*.46)+bob,w*.58,0,Math.PI*2);ctx.stroke();ctx.globalAlpha=1;break;
    case 3:ctx.globalAlpha=.45+Math.sin(t*6)*.28;ctx.fillStyle='#aa00ff';ctx.shadowColor='#aa00ff';ctx.shadowBlur=16;for(let i=0;i<3;i++){const a=t*2+i*Math.PI*.66;ctx.beginPath();ctx.arc(Math.cos(a)*w*.48,(-h*.46)+Math.sin(a)*h*.17+bob,4,0,Math.PI*2);ctx.fill();}ctx.globalAlpha=1;break;
  }
  if(sg){ctx.globalAlpha=.35+Math.sin(t*8)*.18;ctx.strokeStyle=f.def.super.color;ctx.lineWidth=3;ctx.shadowBlur=28;ctx.beginPath();ctx.arc(0,(-h*.5)+bob,w*.8,0,Math.PI*2);ctx.stroke();ctx.globalAlpha=1;}
  ctx.restore();
  // Bonus indicator
  if(gameRunning&&puzzle&&f.def.bonus===puzzle.type){
    ctx.save();ctx.font='14px serif';ctx.textAlign='center';
    ctx.fillStyle=f.color;ctx.shadowColor=f.color;ctx.shadowBlur=8;
    ctx.fillText('🧠',x,y-h-10);ctx.restore();
  }
}

// ══════════════════════════════════════════════════════════
// ONLINE VIA PEERJS (WiFi/LAN — works in APK WebView)
// Usa PeerJS: peer-to-peer directo sin servidor propio
// Ambos teléfonos deben estar en la misma red WiFi
// ══════════════════════════════════════════════════════════
let peer=null,conn=null;

function peerReady(){return typeof Peer!=='undefined';}

function setupConn(c){
  conn=c;
  conn.on('data',function(m){
    if(m.type==='charSelect'){if(isHost)selChars.p2=m.cid;else selChars.p1=m.cid;}
    else if(m.type==='start'){hideLobbyScreens();resetFighters();startRound();}
    else if(m.type==='answer'&&!isHost){
      // Remote P2 answer received on host
    }
  });
  conn.on('open',function(){
    document.getElementById('lstatus').textContent='¡CONECTADO POR WIFI!';
    setTimeout(()=>goCS(isHost?'host':'client'),600);
  });
  conn.on('error',function(e){
    document.getElementById('lstatus').textContent='Error de conexión. Prueba modo local.';
  });
}

function sendMsg(m){if(conn&&conn.open)conn.send(m);}

function goHost(){
  isHost=true;gameMode='host';npcEnabled=false;
  if(!peerReady()){document.getElementById('lstatus').textContent='PeerJS no disponible — modo local';setTimeout(goLocal,2000);return;}
  try{
    const code='BB'+Math.random().toString(36).slice(2,5).toUpperCase();
    peer=new Peer(code,{debug:0});
    peer.on('open',function(id){
      document.getElementById('rcode').textContent=id;
      document.getElementById('rcode').style.display='block';
      document.getElementById('lstatus').textContent='Comparte este código con tu rival (misma WiFi)';
    });
    peer.on('connection',function(c){setupConn(c);});
    peer.on('error',function(e){
      document.getElementById('lstatus').textContent='Sin conexión. Ambos deben estar en la misma WiFi.';
    });
  }catch(e){document.getElementById('lstatus').textContent='Error — modo local';setTimeout(goLocal,1500);}
}

function showJoin(){
  document.getElementById('rinput').style.display='block';
  document.getElementById('jbtn').style.display='block';
  document.getElementById('sjbtn').style.display='none';
}

function goJoin(){
  const code=document.getElementById('rinput').value.toUpperCase().trim();
  if(code.length<2){document.getElementById('lstatus').textContent='Ingresa el código';return;}
  gameMode='client';isHost=false;npcEnabled=false;
  if(!peerReady()){document.getElementById('lstatus').textContent='PeerJS no disponible — modo local';setTimeout(goLocal,2000);return;}
  document.getElementById('lstatus').textContent='Conectando a '+code+'...';
  try{
    peer=new Peer(undefined,{debug:0});
    peer.on('open',function(){
      const c=peer.connect(code,{reliable:true});
      setupConn(c);
    });
    peer.on('error',function(e){
      document.getElementById('lstatus').textContent='No se pudo conectar. Verifica el código y la WiFi.';
    });
  }catch(e){document.getElementById('lstatus').textContent='Error — modo local';setTimeout(goLocal,1500);}
}

function goLocal(){
  gameMode='local';
  npcEnabled=true;
  goCS('local');
}

// ══════════════════════════════════════════════════════════
// CHAR SELECT
// ══════════════════════════════════════════════════════════
let csLocal=0;
function goCS(){
  document.getElementById('lobby').style.display='none';
  document.getElementById('cs').style.display='flex';
  csLocal=0;
  document.getElementById('cssub').textContent=gameMode==='local'?'TÚ (P1) — ELIGE TU PERSONAJE':'TÚ ERES '+(isHost?'P1':'P2')+' — ELIGE';
  if(gameMode==='local'){
    document.getElementById('csst').textContent='P2 será controlado por la CPU';
  }
}

// Event delegation for char cards
document.getElementById('csgrid').addEventListener('click',e=>{
  const card=e.target.closest('.cc');if(!card)return;
  const id=parseInt(card.dataset.id);pickChar(id);
});
document.getElementById('csgrid').addEventListener('touchend',e=>{
  e.preventDefault();
  const t=e.changedTouches[0];
  const el=document.elementFromPoint(t.clientX,t.clientY);
  const card=el&&el.closest('.cc');if(!card)return;
  pickChar(parseInt(card.dataset.id));
},{passive:false});

function pickChar(id){
  document.querySelectorAll('.cc').forEach(c=>c.classList.remove('sel'));
  document.getElementById('cs').querySelector('[data-id="'+id+'"]').classList.add('sel');
  if(gameMode==='local'){
    if(csLocal===0){
      selChars.p1=id;
      document.getElementById('csst').textContent=CHARS[id].name+' seleccionado — CPU elegirá rival';
      // Auto-pick a different CPU character
      const cpuId=(id+1+Math.floor(Math.random()*3))%4;
      selChars.p2=cpuId;
      document.getElementById('cscfm').style.display='block';
      csLocal=1;
      // Show CPU selection visually
      document.querySelectorAll('.cc').forEach(c=>c.classList.remove('sel'));
      document.getElementById('cs').querySelector('[data-id="'+id+'"]').classList.add('sel');
      setTimeout(()=>{
        document.getElementById('cssub').textContent='CPU eligió: '+CHARS[cpuId].name;
        document.getElementById('csst').textContent='Tu personaje: '+CHARS[id].name+' | CPU: '+CHARS[cpuId].name;
      },600);
    }
  } else {
    if(isHost)selChars.p1=id;else selChars.p2=id;
    if(dataChannel&&dataChannel.readyState==='open')dataChannel.send(JSON.stringify({type:'charSelect',cid:id}));
    document.getElementById('cscfm').style.display='block';
  }
}
function confirmChar(){
  document.getElementById('cs').style.display='none';
  if(gameMode==='host'&&dataChannel&&dataChannel.readyState==='open')dataChannel.send(JSON.stringify({type:'start'}));
  hideLobbyScreens();resetFighters();startRound();
}
function hideLobbyScreens(){
  document.getElementById('lobby').style.display='none';
  document.getElementById('cs').style.display='none';
}

// ══════════════════════════════════════════════════════════
// MAIN LOOP
// ══════════════════════════════════════════════════════════
let lastT=0;
function loop(ts){
  const dt=Math.min((ts-lastT)/1000,.05);lastT=ts;
  requestAnimationFrame(loop);
  const t=ts*.001;
  // Fighter timers
  [f1,f2].forEach(f=>{
    if(!f)return;
    f.animT+=dt;if(f.animT>.1){f.animT=0;f.animF=(f.animF+1)%8;}
    if(f.stateT>0){f.stateT-=dt;if(f.stateT<=0&&f.state!=='win')f.state='idle';}
  });
  updParts(dt);
  // Shake
  let sx=0,sy=0;
  if(shakeAmt>0){sx=(Math.random()-.5)*shakeAmt;sy=(Math.random()-.5)*shakeAmt;shakeAmt*=.76;if(shakeAmt<.3)shakeAmt=0;}
  ctx.save();ctx.translate(sx,sy);
  if(bgCanvas)ctx.drawImage(bgCanvas,0,0);else{ctx.fillStyle='#020010';ctx.fillRect(0,0,W,H);}
  if(f1)drawFighter(f1,t);
  if(f2)drawFighter(f2,t);
  drawParts();
  if(flashA>0){ctx.fillStyle=flashC;ctx.globalAlpha=flashA;ctx.fillRect(0,0,W,H);ctx.globalAlpha=1;flashA*=.80;if(flashA<.01)flashA=0;}
  ctx.restore();
}

