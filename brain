<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>BRAIN BOUT</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:rgba(0,0,0,0);}
body{background:#000;overflow:hidden;font-family:'Courier New',monospace;user-select:none;touch-action:none;}
canvas{display:block;position:fixed;top:0;left:0;z-index:0;}

/* ── UI LAYER ── */
#ui{position:fixed;top:0;left:0;width:100%;height:100%;z-index:10;pointer-events:none;}

/* ── HUD TOP ── */
#hud{position:absolute;top:0;left:0;width:100%;padding:6px 8px;display:flex;
     justify-content:space-between;align-items:flex-start;background:rgba(0,0,0,0.5);}
.fhud{display:flex;flex-direction:column;gap:3px;width:38%;}
.fhud.r{align-items:flex-end;}
.fn{font-size:10px;letter-spacing:2px;font-weight:bold;}
.hpw{width:100%;background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.12);
     border-radius:2px;height:11px;overflow:hidden;}
.hpf{height:100%;border-radius:2px;transition:width .12s;}
#hp1{background:linear-gradient(90deg,#ff3300,#ff8800);width:100%;}
#hp2{background:linear-gradient(90deg,#ff8800,#ff3300);width:100%;float:right;}
.pww{width:100%;background:rgba(0,0,0,0.4);border:1px solid rgba(255,200,0,.15);
     border-radius:2px;height:5px;overflow:hidden;}
.pwf{height:100%;border-radius:2px;transition:width .1s;}
#pw1{background:linear-gradient(90deg,#ffcc00,#ffee66);width:0%;}
#pw2{background:linear-gradient(90deg,#ffee66,#ffcc00);width:0%;float:right;}
.stocks{display:flex;gap:3px;}
.sd{width:8px;height:8px;border-radius:50%;background:#333;border:1px solid #666;}
.sd.on{background:#fff;box-shadow:0 0 4px #fff;}
#hud-mid{text-align:center;flex:1;padding-top:2px;}
#timer{font-size:22px;font-weight:bold;color:#fff;letter-spacing:3px;line-height:1;}
#rlbl{font-size:8px;color:#888;letter-spacing:3px;}

/* ── PUZZLE ZONE (middle of screen) ── */
#pz{position:absolute;left:0;right:0;pointer-events:all;overflow:hidden;display:flex;flex-direction:column;background:rgba(0,0,8,0.75);border-top:1px solid rgba(170,68,255,0.3);border-bottom:1px solid rgba(170,68,255,0.3);}
#pz-header{text-align:center;padding:4px 8px 3px;border-bottom:1px solid rgba(255,255,255,0.08);}
#pz-type{font-size:9px;letter-spacing:3px;color:#aa44ff;text-transform:uppercase;}
#pz-q{font-size:13px;color:#fff;letter-spacing:1px;min-height:18px;margin-top:2px;}

/* Progress bars */
#progs{display:flex;gap:6px;padding:4px 8px;}
.prw{flex:1;background:rgba(0,0,0,0.4);border-radius:3px;height:5px;overflow:hidden;
     border:1px solid rgba(255,255,255,0.08);}
.prf{height:100%;border-radius:3px;width:0%;transition:width .1s;}
#pr1{background:#ff6622;}
#pr2{background:#22aaff;}

/* Two-panel layout */
#panels{display:flex;flex:1;overflow:hidden;min-height:0;}
.panel{flex:1;padding:5px 6px;overflow-y:auto;-webkit-overflow-scrolling:touch;min-height:0;max-height:100%;}
.panel:first-child{border-right:1px solid rgba(255,255,255,0.08);}
.plbl{font-size:9px;letter-spacing:2px;margin-bottom:5px;display:block;}

/* Answer buttons — LARGE touch targets */
.abtn{display:block;width:100%;padding:8px 4px;margin-bottom:5px;border-radius:8px;
      font-family:'Courier New',monospace;font-size:13px;font-weight:bold;
      letter-spacing:1px;text-align:center;border:2px solid rgba(255,255,255,0.2);
      background:rgba(255,255,255,0.06);color:#fff;cursor:pointer;
      -webkit-tap-highlight-color:rgba(255,255,255,0.1);
      transition:background .1s,border-color .1s;}
.abtn:active{background:rgba(255,255,255,0.18);}
.abtn.ok{border-color:#44ff88;background:rgba(0,220,80,.2);color:#44ff88;}
.abtn.no{border-color:#ff4444;background:rgba(255,0,0,.15);color:#ff4444;}
.abtn.dim{opacity:.35;pointer-events:none;}

/* Sequence tiles */
.stiles{display:flex;gap:4px;flex-wrap:wrap;justify-content:center;margin-bottom:6px;}
.stile{width:36px;height:36px;border-radius:6px;display:flex;align-items:center;
       justify-content:center;font-size:18px;border:2px solid rgba(255,255,255,0.18);
       background:rgba(255,255,255,0.05);}
.stile.hi{border-color:#ffcc00;background:rgba(255,200,0,.18);}
.stile.dn{border-color:#44ff88;background:rgba(0,220,80,.15);}
.sbgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:5px;}

/* Color puzzle */
.ctarget{font-size:20px;font-weight:bold;text-align:center;letter-spacing:4px;
         padding:6px 0 8px;}
.cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;}
.cbtn{height:42px;border-radius:8px;border:2px solid rgba(255,255,255,0.1);
      cursor:pointer;-webkit-tap-highlight-color:rgba(255,255,255,0.1);}
.cbtn:active{opacity:.7;}

/* Word puzzle */
.wslots{font-size:18px;font-weight:bold;text-align:center;letter-spacing:8px;
        min-height:30px;padding:4px 0 8px;}
.wgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;}
.wbtn{padding:9px 2px;border-radius:6px;font-size:13px;font-weight:bold;
      text-align:center;border:2px solid rgba(255,255,255,0.18);
      background:rgba(255,255,255,0.05);color:#fff;cursor:pointer;
      -webkit-tap-highlight-color:rgba(255,255,255,0.1);}
.wbtn:active{background:rgba(255,255,255,0.2);}
.wbtn.dim{opacity:.3;pointer-events:none;}

/* Math numpad */
.mdisp{font-size:20px;font-weight:bold;text-align:center;letter-spacing:3px;
       color:#fff;min-height:28px;padding:4px 0 6px;
       text-shadow:0 0 12px rgba(255,255,255,.4);}
.minput{font-size:18px;font-weight:bold;text-align:center;
        background:rgba(255,255,255,0.06);border:2px solid rgba(255,255,255,0.18);
        border-radius:6px;color:#ffcc00;padding:5px;letter-spacing:3px;
        min-height:34px;margin-bottom:5px;display:flex;align-items:center;
        justify-content:center;}
.npad{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}
.nbtn{padding:9px 2px;border-radius:6px;font-size:14px;font-weight:bold;
      text-align:center;border:2px solid rgba(255,255,255,0.18);
      background:rgba(255,255,255,0.05);color:#fff;cursor:pointer;
      -webkit-tap-highlight-color:rgba(255,255,255,0.1);}
.nbtn:active{background:rgba(255,255,255,0.2);}

/* ── ANNOUNCE / HIT ── */
#ann{position:absolute;top:35%;left:50%;transform:translate(-50%,-50%);
     text-align:center;pointer-events:none;}
#amain{font-size:42px;font-weight:bold;letter-spacing:6px;opacity:0;
       transition:opacity .3s;text-shadow:0 0 40px currentColor;}
#asub{font-size:12px;letter-spacing:4px;color:#aaa;opacity:0;
      margin-top:5px;transition:opacity .3s;}
#hitd{position:absolute;top:28%;left:50%;transform:translateX(-50%);
      text-align:center;pointer-events:none;}
#httx{font-size:24px;font-weight:bold;letter-spacing:3px;opacity:0;transition:opacity .15s;}
#dmtx{font-size:14px;letter-spacing:2px;color:#ffcc00;opacity:0;margin-top:2px;}

/* ── LOBBY ── */
#lobby{position:fixed;top:0;left:0;width:100%;height:100%;
       background:rgba(0,0,8,.97);z-index:100;display:flex;
       flex-direction:column;align-items:center;justify-content:center;
       gap:12px;pointer-events:all;}
#ltitle{font-size:40px;font-weight:bold;letter-spacing:6px;color:#aa44ff;
        text-shadow:0 0 30px #aa44ff,0 0 60px #aa44ff;}
#lsub{font-size:10px;letter-spacing:4px;color:#888;margin-top:-5px;}
.lbtn{background:transparent;border:2px solid currentColor;padding:12px 34px;
      font-family:'Courier New',monospace;font-size:12px;letter-spacing:3px;
      cursor:pointer;text-transform:uppercase;border-radius:4px;pointer-events:all;}
.lbtn.pu{color:#aa44ff;text-shadow:0 0 8px #aa44ff;}
.lbtn.bl{color:#22aaff;text-shadow:0 0 8px #22aaff;}
.lbtn:active{opacity:.7;}
#lsep{width:180px;height:1px;background:rgba(255,255,255,.1);}
#lstatus{font-size:10px;color:#888;letter-spacing:2px;min-height:14px;text-align:center;}
#rcode{font-size:32px;font-weight:bold;letter-spacing:8px;color:#ffcc00;
       text-shadow:0 0 18px #ffcc00;display:none;}
#rinput{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.2);
        color:#fff;padding:10px 16px;font-family:'Courier New',monospace;
        font-size:15px;letter-spacing:4px;text-align:center;border-radius:4px;
        width:150px;pointer-events:all;display:none;}
#jrow{display:flex;gap:8px;align-items:center;}

/* ── CHAR SELECT ── */
#cs{position:fixed;top:0;left:0;width:100%;height:100%;
    background:rgba(0,0,8,.97);z-index:95;display:none;
    flex-direction:column;align-items:center;justify-content:center;
    gap:14px;pointer-events:all;}
#cstitle{font-size:24px;font-weight:bold;letter-spacing:5px;color:#aa44ff;}
#cssub{font-size:9px;letter-spacing:3px;color:#888;}
#csgrid{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;}
.cc{width:90px;border:2px solid rgba(255,255,255,.18);border-radius:10px;
    padding:10px;cursor:pointer;text-align:center;pointer-events:all;
    background:rgba(255,255,255,.03);transition:all .18s;}
.cc:active,.cc.sel{border-color:#aa44ff;background:rgba(170,68,255,.15);
                   transform:scale(1.05);}
.cce{font-size:38px;margin-bottom:4px;}
.ccn{font-size:9px;letter-spacing:2px;color:#fff;font-weight:bold;}
.cct{font-size:8px;letter-spacing:1px;color:#888;margin-top:1px;}
#csst{font-size:9px;letter-spacing:2px;color:#aaa;min-height:14px;}
#cscfm{display:none;background:transparent;border:2px solid #aa44ff;
       padding:11px 30px;font-family:'Courier New',monospace;font-size:12px;
       letter-spacing:3px;cursor:pointer;color:#aa44ff;pointer-events:all;}

/* ── RESULT ── */
#result{position:fixed;top:0;left:0;width:100%;height:100%;
        background:rgba(0,0,0,.88);z-index:90;display:none;
        flex-direction:column;align-items:center;justify-content:center;
        gap:16px;pointer-events:all;}
#rtitle{font-size:44px;font-weight:bold;letter-spacing:6px;}
#rsub{font-size:12px;letter-spacing:3px;color:#aaa;}
#rbtn{background:transparent;border:2px solid #aa44ff;padding:12px 34px;
      font-family:'Courier New',monospace;font-size:12px;letter-spacing:3px;
      cursor:pointer;color:#aa44ff;pointer-events:all;}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="ui">

  <!-- HUD -->
  <div id="hud">
