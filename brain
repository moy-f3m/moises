<script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
<script>
// ══════════════════════════════════════════════════════════
// CANVAS
// ══════════════════════════════════════════════════════════
const canvas=document.getElementById('c');
const ctx=canvas.getContext('2d');
let W=0,H=0;

function resize(){
  W=canvas.width=window.innerWidth;
  H=canvas.height=window.innerHeight;
  layoutUI();
}
window.addEventListener('resize',resize);

function layoutUI(){
  // HUD height
  const hud=document.getElementById('hud');
  const hudH=hud?hud.offsetHeight:52;
  // Canvas fighter area: bottom 28% of screen
  const fighterTop=H*0.60;
  // Puzzle zone sits between HUD bottom and fighter area
  const pz=document.getElementById('pz');
  if(pz){
    pz.style.top=(hudH+4)+'px';
    pz.style.height=(fighterTop-hudH-8)+'px';
  }
}

// ══════════════════════════════════════════════════════════
// CONSTANTS
// ══════════════════════════════════════════════════════════
const MAX_HP=1000,MAX_POW=100,ROUND_TIME=60,TOTAL_ROUNDS=3;
const FLOOR_R=0.85;

const CHARS={
  0:{name:'KAIRO', color:'#ff6622',emoji:'🔥',
     bonus:'math',  bonusMult:1.25,
     super:{name:'SOLAR FLARE', dmg:320,color:'#ffaa00'}},
  1:{name:'VESPER',color:'#22aaff',emoji:'⚡',
     bonus:'sequence',bonusMult:1.20,
     super:{name:'STORM VORTEX',dmg:300,color:'#00ccff'}},
  2:{name:'HYDRA', color:'#00ccaa',emoji:'🌊',
     bonus:'color', bonusMult:1.30,
     super:{name:'OCEAN CRUSH', dmg:340,color:'#00ffcc'}},
  3:{name:'SHADE', color:'#cc44ff',emoji:'💀',
     bonus:'word',  bonusMult:1.15,
     super:{name:'DEATH RIFT',  dmg:310,color:'#dd00ff'}},
};

// ══════════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════════
let gameMode='local',isHost=false;
let npcEnabled=false,npcTimer=null,npcDelay=10; // NPC answers after ~10s
let peerConn=null,dataChannel=null;
let gameRunning=false,roundNum=1,p1Wins=0,p2Wins=0;
let roundTimer=ROUND_TIME,timerInt=null;
let selChars={p1:0,p2:1},csPhase=0;
let particles=[],hitEffects=[],bgParts=[];
let shakeAmt=0,flashA=0,flashC='#fff';
let f1=null,f2=null;
let bgCanvas=null;

// ══════════════════════════════════════════════════════════
// FIGHTER
// ══════════════════════════════════════════════════════════
function mkFighter(slot,cid){
  return{slot,cid,def:CHARS[cid],name:CHARS[cid].name,color:CHARS[cid].color,
         hp:MAX_HP,power:0,
         x:slot===1?0:0,y:0, // set in resetPos
         state:'idle',stateT:0,animF:0,animT:0,facing:slot===1?1:-1};
}
function resetPos(){
  if(f1){f1.x=W*0.22;f1.y=H*FLOOR_R;}
  if(f2){f2.x=W*0.78;f2.y=H*FLOOR_R;}
}
function resetFighters(){
  f1=mkFighter(1,selChars.p1);
  f2=mkFighter(2,selChars.p2);
  resetPos();
  document.getElementById('n1').textContent=f1.name;
  document.getElementById('n2').textContent=f2.name;
  document.getElementById('n1').style.color=f1.color;
  document.getElementById('n2').style.color=f2.color;
  updateHUD();
}

// ══════════════════════════════════════════════════════════
// PUZZLE ENGINE
// ══════════════════════════════════════════════════════════
const PTYPES=['math','sequence','color','word','pattern','memory','oddone','equation'];
let puzzle=null; // current puzzle data
let pSolved={p1:false,p2:false};
let pLock=false;
// Per-player input state
let pInput={
  p1:{val:'',wordSel:[],wordUsed:{}},
  p2:{val:'',wordSel:[],wordUsed:{}}
};

function shuffle(a){return[...a].sort(()=>Math.random()-.5);}
function rnd(a,b){return a+Math.floor(Math.random()*(b-a+1));}

// ── GENERATORS ──
function genMath(){
  const ops=['+','-','×'];
  const op=ops[Math.floor(Math.random()*3)];
  let a,b,ans;
  if(op==='+'){a=rnd(5,49);b=rnd(5,49);ans=a+b;}
  else if(op==='-'){a=rnd(20,59);b=rnd(1,a-1);ans=a-b;}
  else{a=rnd(2,12);b=rnd(2,12);ans=a*b;}
  const wrong=new Set();
  while(wrong.size<3){const w=ans+rnd(-15,15);if(w!==ans&&w>0)wrong.add(w);}
  return{type:'math',q:`${a} ${op} ${b} = ?`,answer:String(ans),
         opts:shuffle([String(ans),...wrong].map(String))};
}
function genSeq(){
  // Numeric sequences with clear visible pattern
  const seqs=[
    // arithmetic +2
    ()=>{const s=rnd(1,10),d=rnd(2,5);const seq=[s,s+d,s+2*d,s+3*d,s+4*d];return{seq,d:'Suma '+d};},
    // arithmetic +3
    ()=>{const s=rnd(1,8),d=rnd(3,7);const seq=[s,s+d,s+2*d,s+3*d,s+4*d];return{seq,d:'Suma '+d};},
    // descending
    ()=>{const s=rnd(20,50),d=rnd(2,5);const seq=[s,s-d,s-2*d,s-3*d,s-4*d];return{seq,d:'Resta '+d};},
    // multiply x2
    ()=>{const s=rnd(1,4);const seq=[s,s*2,s*4,s*8,s*16];return{seq,d:'×2'};},
    // multiply x3
    ()=>{const s=rnd(1,3);const seq=[s,s*3,s*9,s*27,s*81];return{seq,d:'×3'};},
    // squares
    ()=>({seq:[1,4,9,16,25],d:'Cuadrados'}),
    // Fibonacci-like
    ()=>{const a=rnd(1,5),b=rnd(1,5);return{seq:[a,b,a+b,a+2*b,2*a+3*b],d:'Suma anterior'};},
    // even numbers
    ()=>{const s=rnd(1,5)*2;return{seq:[s,s+2,s+4,s+6,s+8],d:'Pares'};},
    // odd numbers
    ()=>{const s=rnd(0,5)*2+1;return{seq:[s,s+2,s+4,s+6,s+8],d:'Impares'};},
    // +10
    ()=>{const s=rnd(5,20);return{seq:[s,s+10,s+20,s+30,s+40],d:'Suma 10'};},
  ];
  const pick=seqs[Math.floor(Math.random()*seqs.length)]();
  const seq=pick.seq;
  const mi=Math.floor(Math.random()*seq.length); // hide random position
  const ans=seq[mi];
  const disp=seq.map((n,i)=>i===mi?'?':String(n));
  const wrong=new Set();
  while(wrong.size<3){const w=ans+rnd(-8,8);if(w!==ans)wrong.add(w);}
  return{type:'sequence',q:'Patrón: '+pick.d+' | ¿Qué número falta?',
         answer:String(ans),disp,mi,opts:shuffle([String(ans),...wrong].map(String))};
}
function genColor(){
  const cols=[
    {name:'ROJO',h:'#ff3333'},{name:'AZUL',h:'#3366ff'},
    {name:'VERDE',h:'#33cc44'},{name:'AMARILLO',h:'#ffcc00'},
    {name:'MORADO',h:'#aa44ff'},{name:'NARANJA',h:'#ff8800'},
    {name:'CYAN',h:'#00ccff'},{name:'ROSA',h:'#ff44aa'},
  ];
  const target=cols[Math.floor(Math.random()*cols.length)];
  const pool=shuffle(cols).slice(0,6);
  if(!pool.find(c=>c.h===target.h))pool[0]=target;
  return{type:'color',q:'Toca el color: '+target.name,answer:target.h,
         target,opts:shuffle(pool)};
}
function genWord(){
  const words=[
    {w:'FUEGO',pool:['F','U','E','G','O','R','A','T']},
    {w:'RAYO', pool:['R','A','Y','O','B','M','L','S']},
    {w:'AGUA', pool:['A','G','U','A','K','P','W','Z']},
    {w:'MENTE',pool:['M','E','N','T','E','X','B','D']},
    {w:'PODER',pool:['P','O','D','E','R','Q','H','V']},
    {w:'GOLPE',pool:['G','O','L','P','E','C','N','I']},
    {w:'LUCHA',pool:['L','U','C','H','A','X','B','D']},
    {w:'FURIA',pool:['F','U','R','I','A','K','P','W']},
  ];
  const pick=words[Math.floor(Math.random()*words.length)];
  return{type:'word',q:'Forma la palabra',answer:pick.w,
         letters:shuffle([...pick.pool])};
}

// ── PATTERN: number sequence ──
function genPattern(){
  const patterns=[
    {seq:[2,4,6,8],next:10},{seq:[1,3,5,7],next:9},{seq:[5,10,15,20],next:25},
    {seq:[1,2,4,8],next:16},{seq:[3,6,9,12],next:15},{seq:[10,8,6,4],next:2},
    {seq:[1,4,9,16],next:25},{seq:[2,6,12,20],next:30},{seq:[100,90,80,70],next:60},
    {seq:[1,1,2,3],next:5},{seq:[2,3,5,8],next:13},{seq:[50,25,12,6],next:3},
  ];
  const p=patterns[Math.floor(Math.random()*patterns.length)];
  const wrong=new Set();
  while(wrong.size<3){const w=p.next+rnd(-8,8);if(w!==p.next&&w>0)wrong.add(w);}
  return{type:'pattern',q:p.seq.join(' , ')+' , ?',answer:String(p.next),
         opts:shuffle([String(p.next),...wrong].map(String))};
}

// ── MEMORY: show then hide ──
function genMemory(){
  const nums=Array.from({length:6},()=>rnd(1,9));
  const target=nums[Math.floor(Math.random()*nums.length)];
  const pos=nums.indexOf(target);
  const wrong=new Set();
  while(wrong.size<3){const w=rnd(1,9);if(w!==target)wrong.add(w);}
  return{type:'memory',q:'Memoriza y encuentra el número en posición '+(pos+1),
         nums,pos,answer:String(target),opts:shuffle([String(target),...wrong].map(String)),
         phase:'show',showTimer:2.5};
}

// ── ODD ONE OUT: find the one that doesn't belong ──
function genOddOne(){
  const sets=[
    {items:['2','4','6','9'],odd:'9',rule:'Impar'},
    {items:['3','6','9','8'],odd:'8',rule:'No múltiplo de 3'},
    {items:['Rojo','Azul','Verde','Piano'],odd:'Piano',rule:'No es color'},
    {items:['Perro','Gato','Mesa','Pez'],odd:'Mesa',rule:'No es animal'},
    {items:['Sol','Luna','Tierra','Auto'],odd:'Auto',rule:'No es astro'},
    {items:['5','10','15','13'],odd:'13',rule:'No múltiplo de 5'},
    {items:['A','E','I','B'],odd:'B',rule:'No es vocal'},
    {items:['1','4','9','7'],odd:'7',rule:'No es cuadrado perfecto'},
    {items:['Círculo','Cuadrado','Triángulo','Rojo'],odd:'Rojo',rule:'No es figura'},
    {items:['Enero','Marzo','Julio','Lunes'],odd:'Lunes',rule:'No es mes'},
  ];
  const p=sets[Math.floor(Math.random()*sets.length)];
  return{type:'oddone',q:'¿Cuál NO pertenece al grupo?',
         answer:p.odd,opts:shuffle([...p.items]),rule:p.rule};
}

// ── EQUATION: solve for X ──
function genEquation(){
  const templates=[
    ()=>{const x=rnd(2,12),a=rnd(2,8);return{q:`X + ${a} = ${x+a}`,ans:x};},
    ()=>{const x=rnd(2,12),a=rnd(1,x-1);return{q:`X - ${a} = ${x-a}`,ans:x};},
    ()=>{const x=rnd(2,9),a=rnd(2,6);return{q:`X × ${a} = ${x*a}`,ans:x};},
    ()=>{const a=rnd(2,6),x=rnd(2,8);return{q:`${a*x} ÷ ${a} = X`,ans:x};},
    ()=>{const x=rnd(2,10),a=rnd(2,5),b=rnd(1,6);return{q:`${a} × X + ${b} = ${a*x+b}`,ans:x};},
    ()=>{const x=rnd(1,10),a=rnd(x,15);return{q:`${a} - X = ${a-x}`,ans:x};},
  ];
  const t=templates[Math.floor(Math.random()*templates.length)]();
  const wrong=new Set();
  while(wrong.size<3){const w=t.ans+rnd(-6,6);if(w!==t.ans&&w>0)wrong.add(w);}
  return{type:'equation',q:'Resuelve: '+t.q,answer:String(t.ans),
         opts:shuffle([String(t.ans),...wrong].map(String))};
}

function genPuzzle(){
  const type=PTYPES[(roundNum-1)%PTYPES.length];
  if(type==='math')     return genMath();
  if(type==='sequence') return genSeq();
  if(type==='color')    return genColor();
  if(type==='word')     return genWord();
  if(type==='pattern')  return genPattern();
  if(type==='memory')   return genMemory();
  if(type==='oddone')   return genOddOne();
  if(type==='equation') return genEquation();
  return genMath();
}

