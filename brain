// ── EVENT DELEGATION — single handler on #pz ──
document.getElementById('pz').addEventListener('click',handlePuzzleClick);
document.getElementById('pz').addEventListener('touchend',function(e){
  e.preventDefault();
  // find topmost element with dataset.action
  const touch=e.changedTouches[0];
  const el=document.elementFromPoint(touch.clientX,touch.clientY);
  if(el)handlePuzzleClick({target:el});
},{passive:false});

function handlePuzzleClick(e){
  if(!gameRunning||pLock)return;
  let el=e.target;
  // Walk up to find action element
  for(let i=0;i<4;i++){
    if(el&&el.dataset&&el.dataset.action)break;
    el=el&&el.parentElement;
  }
  if(!el||!el.dataset||!el.dataset.action)return;
  const pKey=el.dataset.player;
  if(!pKey)return;
  if(pSolved[pKey])return;

  if(el.dataset.action==='answer'){
    checkAnswer(pKey,el.dataset.val,el);
  } else if(el.dataset.action==='numpad'){
    handleNumpad(pKey,el.dataset.key,el);
  } else if(el.dataset.action==='word'){
    handleWord(pKey,parseInt(el.dataset.idx),el.dataset.letter,el);
  } else if(el.dataset.action==='memhide'){
    pInput[pKey].memPhase='answer';buildPanel(pKey);
  }
}

function checkAnswer(pKey,val,el){
  const correct=(String(val)===String(puzzle.answer));
  if(correct){
    el&&el.classList.add('ok');
    // Dim all buttons for this player
    const panel=document.getElementById(pKey==='p1'?'pan1':'pan2');
    panel.querySelectorAll('[data-action]').forEach(b=>b.classList.add('dim'));
    pSolved[pKey]=true;
    document.getElementById('pr'+(pKey==='p1'?'1':'2')).style.width='100%';
    onSolved(pKey);
  } else {
    el&&el.classList.add('no');
    setTimeout(()=>el&&el.classList.remove('no'),450);
    const f=pKey==='p1'?f1:f2;
    f.power=Math.max(0,f.power-5);updateHUD();
  }
}

function handleNumpad(pKey,key,el){
  const inp=pInput[pKey];
  if(key==='✗'){inp.val='';rebuildNumInput(pKey);return;}
  if(key==='✓'){
    if(inp.val==='')return;
    checkAnswer(pKey,inp.val,null);
    return;
  }
  if(inp.val.length<5){
    inp.val+=key;
    rebuildNumInput(pKey);
  }
}
function rebuildNumInput(pKey){
  const el=document.getElementById(pKey+'-minput');
  if(el)el.textContent=pInput[pKey].val||'_';
}

function handleWord(pKey,idx,letter,el){
  const inp=pInput[pKey];
  if(inp.wordUsed[idx])return;
  const expected=puzzle.answer[inp.wordSel.length];
  if(letter===expected){
    inp.wordSel.push(letter);
    inp.wordUsed[idx]=true;
    const pct=inp.wordSel.length/puzzle.answer.length*100;
    document.getElementById('pr'+(pKey==='p1'?'1':'2')).style.width=pct+'%';
    buildPanel(pKey); // re-render to show progress + dim used
    if(inp.wordSel.join('')===puzzle.answer){
      pSolved[pKey]=true;
      onSolved(pKey);
    }
  } else {
    el&&el.classList.add('no');
    setTimeout(()=>el&&el.classList.remove('no'),400);
  }
}

function onSolved(pKey){
  const attacker=pKey==='p1'?f1:f2;
  const defender=pKey==='p1'?f2:f1;
  const defKey=pKey==='p1'?'p2':'p1';
  let dmg=110+rnd(0,70);
  if(attacker.def.bonus===puzzle.type)dmg=Math.floor(dmg*attacker.def.bonusMult);
  if(!pSolved[defKey])dmg+=40; // first-solve bonus
  attacker.power=Math.min(MAX_POW,attacker.power+22);
  dealDamage(pKey,defKey,dmg);
  if(attacker.power>=MAX_POW){
    setTimeout(()=>{if(gameRunning)doSuper(pKey,defKey);},500);
  } else {
    setTimeout(()=>{if(gameRunning)newPuzzle();},1000);
  }
}

function dealDamage(atkKey,defKey,dmg){
  const atk=atkKey==='p1'?f1:f2;
  const def=defKey==='p1'?f1:f2;
  def.hp=Math.max(0,def.hp-dmg);
  def.state='hurt';def.stateT=0.5;
  atk.state='attack';atk.stateT=0.6;
  shakeAmt=dmg>160?10:6;flashA=0.3;flashC=atk.color;
  spawnBurst(def.x,def.y-80,atk.color,10);
  spawnFx(def.x,def.y-120,'-'+dmg,atk.color,1.1);
  showHit(atk.name+' ATACA',atk.color,dmg);
  updateHUD();
  if(def.hp<=0){pLock=true;setTimeout(()=>endRound(atkKey==='p1'?1:2,'K.O.!'),700);}
}

function doSuper(atkKey,defKey){
  const atk=atkKey==='p1'?f1:f2;
  const def=defKey==='p1'?f1:f2;
  atk.power=0;atk.state='super';atk.stateT=1.3;pLock=true;
  flashA=0.85;flashC=atk.def.super.color;shakeAmt=18;
  setTimeout(()=>{
    def.hp=Math.max(0,def.hp-atk.def.super.dmg);
    spawnBurst(def.x,def.y-80,atk.def.super.color,22);
    spawnFx(atk.x,atk.y-140,'⚡'+atk.def.super.name+'!!',atk.def.super.color,1.5);
    showHit('⚡ '+atk.def.super.name+' ⚡',atk.def.super.color,atk.def.super.dmg);
    updateHUD();
    if(def.hp<=0)endRound(atkKey==='p1'?1:2,'K.O.!');
    else{pLock=false;newPuzzle();}
  },400);
}

function newPuzzle(){
  if(!gameRunning)return;
  puzzle=genPuzzle();
  pSolved={p1:false,p2:false};
  pInput={p1:{val:'',wordSel:[],wordUsed:{},memPhase:'show'},p2:{val:'',wordSel:[],wordUsed:{},memPhase:'show'}};
  pLock=false;
  renderPuzzle();
  // Schedule NPC answer for player 2 in local mode
  if(npcEnabled){
    clearTimeout(npcTimer);
    const delay=(npcDelay+Math.random()*5)*1000; // 10-15 seconds
    npcTimer=setTimeout(()=>{
      if(!gameRunning||pSolved.p2||pLock)return;
      npcAnswer();
    },delay);
  }
}

function npcAnswer(){
  if(!puzzle||pSolved.p2||!gameRunning)return;
  // NPC always picks correct answer (it's the AI)
  if(puzzle.type==='word'){
    // Simulate word selection letter by letter
    const inp=pInput.p2;
    let delay=0;
    puzzle.answer.split('').forEach((letter,li)=>{
      setTimeout(()=>{
        if(!gameRunning||pSolved.p2)return;
        // find unused index with this letter
        const idx=puzzle.letters.findIndex((l,i)=>l===letter&&(!inp.wordUsed||!inp.wordUsed[i]));
        if(idx>=0)handleWord('p2',idx,letter,null);
      },delay);
      delay+=300+Math.random()*200;
    });
  } else if(puzzle.type==='memory'){
    pInput.p2.memPhase='answer';
    buildPanel('p2');
    setTimeout(()=>{if(gameRunning&&!pSolved.p2)checkAnswer('p2',puzzle.answer,null);},800);
  } else {
    // For all other types, just submit correct answer
    checkAnswer('p2',puzzle.answer,null);
    // Highlight correct button visually
    const pan=document.getElementById('pan2');
    if(pan){
      const btns=pan.querySelectorAll('[data-action="answer"],[data-action="numpad"]');
      btns.forEach(b=>{
        if((b.dataset.val||b.dataset.key)===puzzle.answer){b.classList.add('ok');}
      });
    }
  }
}

