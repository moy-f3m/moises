  <div id="csgrid">
    <div class="cc" data-id="0"><div class="cce">🔥</div><div class="ccn">KAIRO</div><div class="cct">STRIKER</div></div>
    <div class="cc" data-id="1"><div class="cce">⚡</div><div class="ccn">VESPER</div><div class="cct">SPEEDSTER</div></div>
