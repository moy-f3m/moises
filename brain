    pattern:'PATRON NUMERICO',memory:'MEMORIA',oddone:'INTRUSO',equation:'ECUACION'};
  document.getElementById('pz-type').textContent=(puzzle?typeNames[puzzle.type]||puzzle.type:'')+' DUEL';
  document.getElementById('pz-q').textContent=puzzle?puzzle.q:'';
