function updateThree(px,py,bossActive,waveNum){
  if(!threeReady)return;
  const dt=threeClock.getDelta(),t=threeClock.elapsedTime;
  _threeFrame++;
  const tier=Math.min(Math.floor((waveNum-1)/5),5);
  const everyOther=(_threeFrame%2===0);

  // ── Camera ──
  threeCamera.position.x+=((px-WORLD/2)/5.5-threeCamera.position.x)*.05;
  threeCamera.position.z+=(((py-WORLD/2)/5.5-28)-threeCamera.position.z)*.05;
  threeCamera.lookAt(threeCamera.position.x,0,threeCamera.position.z+135);

  // ── Rain: only update every other frame ──
  if(everyOther&&threeRain){
    const p=threeRain.geometry.attributes.position;
    for(let i=0;i<p.count;i++){p.setY(i,p.getY(i)-4.4);if(p.getY(i)<0)p.setY(i,380);}
    p.needsUpdate=true;
  }

  // ── Crystals: only rotate, no bobbing every frame ──
  threeCrystals.forEach(c=>{c.rotation.x+=c._rX;c.rotation.y+=c._rY;});
  // Bob only every 2 frames
  if(everyOther) threeCrystals.forEach(c=>{c.position.y=c._baseY+Math.sin(t+c._bobPhase)*5;});

  // ── Building beacons: every 3 frames ──
  if(_threeFrame%3===0) threeBuildings.forEach(b=>{if(b.beacon)b.beacon.material.opacity=0.3+Math.sin(t*2.5+b.phase)*.55;});

  // ── Pillar lights pulse: every 2 frames ──
  if(everyOther) threeLights.forEach(l=>{
    l.light.intensity=(bossActive?5:3.5)+Math.sin(t*2+l.phase)*1.5;
    l.ring.rotation.y+=.04;
  });

  // ── Holo towers ──
  if(everyOther) threeHoloTowers.forEach(h=>{
    h.rings.forEach((r,i)=>r.rotation.y+=.02+i*.01);
    h.diam.rotation.y+=.025;
  });

  // ── Portals ──
  if(_threeFrame%3===0) threePortals.forEach(p=>{p.arch.rotation.y+=.006;});

  // ── Spaceships: every 2 frames ──
  if(everyOther) threeSpaceships.forEach(s=>{
    s._orbitAng+=s._orbitSpeed;
    s.position.x=Math.cos(s._orbitAng)*s._orbitRad;
    s.position.z=Math.sin(s._orbitAng)*s._orbitRad;
    s.position.y=88+Math.sin(t*.4+s._bobPhase)*18;
    s.rotation.y=-s._orbitAng+Math.PI/2;
  });

  // ── Floor + fog ──
  if(_threeFrame%4===0){
    const floorCols=[0x000820,0x08001a,0x100008,0x0a0015,0x130b00,0x1a0008];
    const fogCols=[0x000510,0x060012,0x090006,0x060010,0x090600,0x0b0008];
    threeFloor.material.emissive.setHex(floorCols[tier]);
    threeFloor.material.emissiveIntensity=0.18+(bossActive?.1:0);
    threeScene.fog.color.setHex(fogCols[tier]);
    threeScene.fog.density=0.0014+tier*.0003+(bossActive?.001:0);
    if(threeAurora)threeAurora.material.color.setHex([0x000820,0x060018,0x110006,0x09000f,0x110900,0x100018][tier]);
  }

  threeRenderer.render(threeScene,threeCamera);
}

