function playTone(freq,dur,type='sine',vol=0.3,detune=0,delay=0){
  if(!audioCtx)return;
  const o=audioCtx.createOscillator(),g=audioCtx.createGain(),t=audioCtx.currentTime+delay;
  o.connect(g);g.connect(audioCtx.destination);o.type=type;o.frequency.value=freq;o.detune.value=detune;
  g.gain.setValueAtTime(0.001,t);g.gain.linearRampToValueAtTime(vol,t+0.012);g.gain.exponentialRampToValueAtTime(0.001,t+dur);
  o.start(t);o.stop(t+dur+0.05);
}
