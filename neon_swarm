<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-fullscreen">
<title>NEON SWARM: SURVIVORS</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{background:#000;overflow:hidden;font-family:'Courier New',monospace;user-select:none;}
#three-bg{position:fixed;top:0;left:0;z-index:0;pointer-events:none;}
#c{position:fixed;top:0;left:0;z-index:1;pointer-events:none;}
#ui{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:10;}
#hud{position:absolute;top:16px;left:16px;}
.bar-wrap{margin-bottom:6px;}
.bar-label{color:#888;font-size:10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:2px;}
.bar-bg{background:rgba(0,0,0,0.7);border:1px solid rgba(255,255,255,0.12);border-radius:3px;overflow:hidden;}
#hp-bar{width:220px;height:14px;}
#hp-fill{height:100%;background:linear-gradient(90deg,#ff006e,#ff4da6);width:100%;transition:width 0.1s;}
#mp-bar{width:220px;height:9px;}
#mp-fill{height:100%;background:linear-gradient(90deg,#0066ff,#00e5ff);width:100%;transition:width 0.1s;}
#xp-bar{width:220px;height:5px;margin-top:4px;}
#xp-fill{height:100%;background:linear-gradient(90deg,#7b2fff,#ff00ff);width:0%;transition:width 0.3s;}
#level-txt{color:#bf00ff;font-size:11px;letter-spacing:2px;margin-top:3px;}
#score-ui{position:absolute;top:16px;right:16px;text-align:right;}
#wave-txt{color:#00f0ff;font-size:13px;letter-spacing:3px;font-weight:bold;}
#score-txt{color:#ff00aa;font-size:13px;letter-spacing:2px;margin-top:4px;}
#kills-txt{color:#888;font-size:11px;margin-top:2px;}
#skills-ui{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);display:flex;gap:10px;}
.skill-btn{width:64px;height:64px;border:2px solid rgba(255,255,255,0.3);border-radius:8px;background:rgba(0,0,0,0.8);position:relative;overflow:hidden;pointer-events:none;}
.skill-icon{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:24px;}
.skill-cd{position:absolute;bottom:0;left:0;width:100%;background:rgba(0,0,0,0.75);height:0%;}
.skill-key{position:absolute;top:2px;left:4px;font-size:9px;color:#aaa;}
.skill-cost{position:absolute;bottom:2px;right:3px;font-size:9px;color:#00b4ff;}
#center-msg{position:absolute;top:38%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;}
#wave-announce{font-size:48px;color:#00f0ff;letter-spacing:6px;font-weight:bold;text-shadow:0 0 30px #00f0ff,0 0 60px #00f0ff;opacity:0;transition:opacity 0.5s;}
#sub-announce{font-size:16px;color:#ff00aa;letter-spacing:4px;margin-top:8px;opacity:0;transition:opacity 0.5s;}
#boss-hpbar{position:absolute;bottom:96px;left:50%;transform:translateX(-50%);width:480px;display:none;}
#boss-name{font-size:13px;letter-spacing:3px;text-align:center;margin-bottom:5px;color:#ff0055;text-shadow:0 0 12px #ff0055;}
#boss-hp-bg{background:rgba(0,0,0,0.75);border-radius:4px;overflow:hidden;height:18px;}
#boss-hp-fill{height:100%;width:100%;background:linear-gradient(90deg,#ff0055,#ff4488);transition:width 0.15s;}
#overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,6,0.95);z-index:100;display:flex;align-items:center;justify-content:center;flex-direction:column;}
#overlay-title{font-size:62px;letter-spacing:8px;font-weight:bold;margin-bottom:8px;}
#overlay-sub{font-size:16px;letter-spacing:4px;color:#888;margin-bottom:10px;}
#overlay-sub2{font-size:11px;letter-spacing:2px;color:#444;margin-bottom:42px;text-align:center;max-width:640px;line-height:1.8;}
#overlay-btn{background:transparent;border:2px solid currentColor;padding:15px 56px;font-family:'Courier New',monospace;font-size:14px;letter-spacing:4px;cursor:pointer;pointer-events:all;transition:all 0.2s;text-transform:uppercase;}
#overlay-btn:hover{background:rgba(255,255,255,0.07);}
#controls-hint{display:none;}
/* ── VIRTUAL JOYSTICK ── */
#joystick-zone{position:absolute;bottom:20px;left:20px;width:160px;height:160px;border-radius:50%;background:rgba(0,240,255,0.05);border:2px solid rgba(0,240,255,0.2);pointer-events:all;touch-action:none;}
#joystick-base{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:70px;height:70px;border-radius:50%;background:rgba(0,240,255,0.1);border:2px solid rgba(0,240,255,0.3);}
#joystick-knob{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:40px;height:40px;border-radius:50%;background:radial-gradient(circle,rgba(0,240,255,0.9),rgba(0,150,255,0.5));border:2px solid #00f0ff;box-shadow:0 0 15px rgba(0,240,255,0.6);transition:none;}
/* ── MOBILE SKILL BUTTONS ── */
#mobile-skills{position:absolute;bottom:20px;right:20px;display:grid;grid-template-columns:1fr 1fr;gap:10px;pointer-events:all;touch-action:none;}
.m-skill{width:72px;height:72px;border-radius:12px;background:rgba(0,0,0,0.8);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden;border:2px solid rgba(255,255,255,0.3);-webkit-tap-highlight-color:transparent;touch-action:none;user-select:none;}
.m-skill:active{transform:scale(0.93);}
.m-skill .s-icon{font-size:26px;line-height:1;}
.m-skill .s-key{position:absolute;top:3px;left:5px;font-size:8px;color:rgba(255,255,255,0.5);font-family:'Courier New',monospace;}
.m-skill .s-cost{position:absolute;bottom:3px;right:4px;font-size:8px;color:#00b4ff;font-family:'Courier New',monospace;}
.m-skill .s-cd{position:absolute;bottom:0;left:0;width:100%;height:0%;transition:none;}
/* ── AIM INDICATOR ── */
#aim-indicator{position:absolute;top:50%;left:50%;width:30px;height:30px;transform:translate(-50%,-50%);pointer-events:none;opacity:0.5;}
/* ── MOBILE OVERLAY BTN ── */
#overlay-btn{padding:18px 52px;font-size:16px;-webkit-tap-highlight-color:transparent;}
.upgrade-opt{padding:16px;margin-bottom:12px;min-height:60px;-webkit-tap-highlight-color:transparent;}
#levelup-panel{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,8,0.97);border:1px solid #bf00ff;border-radius:14px;padding:30px;display:none;z-index:50;pointer-events:all;min-width:380px;box-shadow:0 0 40px rgba(191,0,255,0.3);}
#levelup-panel h2{color:#bf00ff;font-size:18px;letter-spacing:4px;text-align:center;margin-bottom:20px;}
.upgrade-opt{border:1px solid rgba(255,255,255,0.1);border-radius:9px;padding:14px;margin-bottom:10px;cursor:pointer;transition:all 0.18s;pointer-events:all;}
.upgrade-opt:hover{border-color:#bf00ff;background:rgba(191,0,255,0.1);}
.upgrade-opt .opt-name{color:#fff;font-size:13px;letter-spacing:2px;margin-bottom:4px;}
.upgrade-opt .opt-desc{color:#666;font-size:11px;}
.upgrade-opt .opt-icon{font-size:22px;margin-bottom:6px;}
#minimap{position:absolute;top:90px;right:16px;border:1px solid rgba(0,240,255,0.3);border-radius:5px;}
#wave-progress{position:absolute;top:16px;left:50%;transform:translateX(-50%);display:flex;gap:5px;align-items:center;}
.wave-dot{width:9px;height:9px;border-radius:50%;border:1px solid rgba(255,255,255,0.2);transition:all 0.3s;}
</style>
</head>
<body>
<canvas id="three-bg"></canvas>
<canvas id="c"></canvas>
<div id="ui">
  <div id="hud">
    <div class="bar-wrap"><div class="bar-label">HP</div><div class="bar-bg" id="hp-bar"><div id="hp-fill"></div></div></div>
    <div class="bar-wrap"><div class="bar-label">MANA</div><div class="bar-bg" id="mp-bar"><div id="mp-fill"></div></div></div>
    <div class="bar-wrap"><div id="xp-bar" class="bar-bg"><div id="xp-fill"></div></div><div id="level-txt">LVL 1 — 0 / 100 XP</div></div>
  </div>
  <div id="score-ui">
    <div id="wave-txt">WAVE 1 / 30</div>
    <div id="score-txt">SCORE: 0</div>
    <div id="kills-txt">KILLS: 0</div>
  </div>
  <div id="wave-progress"></div>
  <!-- Virtual Joystick -->
  <div id="joystick-zone">
    <div id="joystick-base">
      <div id="joystick-knob"></div>
    </div>
  </div>
  <!-- Mobile Skill Buttons -->
  <div id="mobile-skills">
    <div class="m-skill" id="msk0" style="border-color:#00f0ff" ontouchstart="castSkill(0);return false;">
      <div class="s-icon">💫</div>
      <div class="s-cd" id="sk0-cd" style="background:rgba(0,240,255,0.4)"></div>
      <div class="s-key">Q</div><div class="s-cost">30</div>
    </div>
    <div class="m-skill" id="msk1" style="border-color:#ff00aa" ontouchstart="castSkill(1);return false;">
      <div class="s-icon">💥</div>
      <div class="s-cd" id="sk1-cd" style="background:rgba(255,0,170,0.4)"></div>
      <div class="s-key">F</div><div class="s-cost">40</div>
    </div>
    <div class="m-skill" id="msk2" style="border-color:#7b2fff" ontouchstart="castSkill(2);return false;">
      <div class="s-icon">🛡️</div>
      <div class="s-cd" id="sk2-cd" style="background:rgba(123,47,255,0.4)"></div>
      <div class="s-key">E</div><div class="s-cost">50</div>
    </div>
    <div class="m-skill" id="msk3" style="border-color:#ff8800" ontouchstart="castSkill(3);return false;">
      <div class="s-icon">🚀</div>
      <div class="s-cd" id="sk3-cd" style="background:rgba(255,136,0,0.4)"></div>
      <div class="s-key">R</div><div class="s-cost">60</div>
    </div>
  </div>
  <!-- Hidden desktop skills (keep IDs for compatibility) -->
  <div id="skills-ui" style="display:none">
    <div class="skill-btn" id="sk0"><div class="skill-icon">💫</div></div>
    <div class="skill-btn" id="sk1"><div class="skill-icon">💥</div></div>
    <div class="skill-btn" id="sk2"><div class="skill-icon">🛡️</div></div>
    <div class="skill-btn" id="sk3"><div class="skill-icon">🚀</div></div>
  </div>
  <div id="center-msg"><div id="wave-announce"></div><div id="sub-announce"></div></div>
  <div id="boss-hpbar"><div id="boss-name">⚡ NEON GOLEM ⚡</div><div id="boss-hp-bg"><div id="boss-hp-fill"></div></div></div>
  <canvas id="minimap" width="84" height="84"></canvas>
  <div id="levelup-panel"><h2>⬆ LEVEL UP ⬆</h2><div id="upgrade-choices"></div></div>
  <div id="controls-hint">WASD MOVE | MOUSE AIM<br>Q/F/E/R SKILLS | AUTO FIRE<br>30 WAVES · 6 BOSSES</div>
</div>
<div id="overlay">
  <div id="overlay-title" style="color:#00f0ff;text-shadow:0 0 30px #00f0ff,0 0 70px #00f0ff;">NEON SWARM</div>
  <div id="overlay-sub">SURVIVORS</div>
  <div id="overlay-sub2">30 WAVES · 6 BOSSES · 9 ENEMY TYPES<br>WASD move · Mouse aim · Q/F/E/R skills · Auto-fire</div>
  <button id="overlay-btn" style="color:#00f0ff;text-shadow:0 0 12px #00f0ff;" onclick="startGame()">► START RUN</button>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>// ── THREE.JS 3D BACKGROUND — PERFORMANCE OPTIMIZED ──
let threeScene,threeCamera,threeRenderer,threeClock,threeReady=false;
let threeFloor,threeRain,threeBuildings=[],threeCrystals=[],threeLights=[],threeAurora;
let threePortals=[],threeHoloTowers=[],threeSpaceships=[];
let _threeFrame=0;

function mkMat(col,emissive,emInt,rough=0.7,metal=0.3){
  return new THREE.MeshLambertMaterial({color:col,emissive:emissive,emissiveIntensity:emInt});
}
function mkBasic(col,alpha=1){
  return new THREE.MeshBasicMaterial({color:col,transparent:alpha<1,opacity:alpha});
}

function initThree(){
  const bg=document.getElementById('three-bg');
  bg.width=window.innerWidth;bg.height=window.innerHeight;
  threeScene=new THREE.Scene();
  threeScene.fog=new THREE.FogExp2(0x000510,0.0016);

  threeCamera=new THREE.PerspectiveCamera(55,window.innerWidth/window.innerHeight,1,2500);
  threeCamera.position.set(0,150,-20);threeCamera.lookAt(0,0,140);

  threeRenderer=new THREE.WebGLRenderer({canvas:bg,antialias:false,powerPreference:'high-performance'});
  threeRenderer.setSize(window.innerWidth,window.innerHeight);
  threeRenderer.setPixelRatio(1); // always 1 for perf
  threeRenderer.setClearColor(0x000308,1);
  threeRenderer.shadowMap.enabled=false; // DISABLED — major perf win
  threeClock=new THREE.Clock();

  // ── FLOOR ──
  threeFloor=new THREE.Mesh(
    new THREE.PlaneGeometry(3500,3500,2,2), // minimal segments
    new THREE.MeshLambertMaterial({color:0x010108,emissive:0x000820,emissiveIntensity:0.3})
  );
  threeFloor.rotation.x=-Math.PI/2;threeScene.add(threeFloor);

  // ── GRID (single, efficient) ──
  const _g1=new THREE.GridHelper(3500,80,0x002244,0x001122);_g1.position.y=0.3;threeScene.add(_g1);
  const g2=new THREE.GridHelper(3500,20,0x004488,0x002244);g2.position.y=0.5;threeScene.add(g2);

  // ── ROAD LINES (4 main only) ──
  const roadMat=mkBasic(0x00f0ff,0.1);
  [-200,0,200].forEach(v=>{
    [true,false].forEach(horiz=>{
      const m=new THREE.Mesh(horiz?new THREE.PlaneGeometry(3500,2.5):new THREE.PlaneGeometry(2.5,3500),roadMat);
      m.rotation.x=-Math.PI/2;m.position.set(horiz?0:v,0.4,horiz?v:0);threeScene.add(m);
    });
  });

  // ── BUILDINGS: 50 total, no shadows, MeshLambertMaterial ──
  const bColors=[0x00f0ff,0xff00aa,0xbf00ff,0xff8800,0x00ffaa,0xff2255,0x00aaff,0xffff00];
  const buildTiers=[
    {cnt:25,rMin:380,rMax:800, wMn:22,wMx:60,hMn:60, hMx:260},
    {cnt:18,rMin:800,rMax:1300,wMn:38,wMx:100,hMn:120,hMx:440},
    {cnt:12,rMin:1300,rMax:1900,wMn:55,wMx:150,hMn:200,hMx:650},
  ];
  buildTiers.forEach(({cnt,rMin,rMax,wMn,wMx,hMn,hMx})=>{
    for(let i=0;i<cnt;i++){
      const w=wMn+Math.random()*(wMx-wMn),h=hMn+Math.random()*(hMx-hMn),d=wMn+Math.random()*(wMx-wMn);
      const col=bColors[Math.floor(Math.random()*bColors.length)];
      const ang=Math.random()*Math.PI*2,rad=rMin+Math.random()*(rMax-rMin);
      const geo=new THREE.BoxGeometry(w,h,d);
      const mesh=new THREE.Mesh(geo,mkMat(0x010108,col,0.025));
      mesh.position.set(Math.cos(ang)*rad,h/2,Math.sin(ang)*rad);
      threeScene.add(mesh);
      // Edges only on close buildings
      if(rad<900){
        mesh.add(new THREE.LineSegments(
          new THREE.EdgesGeometry(geo),
          new THREE.LineBasicMaterial({color:col,transparent:true,opacity:0.25})
        ));
      }
      // Antenna beacon on some
      if(Math.random()>.5&&h>80){
        const beacon=new THREE.Mesh(
          new THREE.SphereGeometry(2,5,5),
          new THREE.MeshBasicMaterial({color:col,transparent:true,opacity:0.9})
        );
        beacon.position.y=h/2+12;beacon._phase=Math.random()*Math.PI*2;
        mesh.add(beacon);threeBuildings.push({beacon,phase:beacon._phase});
      }
    }
  });

  // ── ARENA PILLARS: 8 only, no shadows ──
  const pillarPos=[[-480,0,-480],[-480,0,0],[-480,0,480],[0,0,-480],[0,0,480],[480,0,-480],[480,0,0],[480,0,480]];
  const pillarCols=[0x00f0ff,0xff00aa,0xbf00ff,0xff8800,0x00ffaa,0xff2255,0x00aaff,0xffff00];
  pillarPos.forEach(([px,_,pz],pi)=>{
    const pc=pillarCols[pi];
    const shaft=new THREE.Mesh(new THREE.CylinderGeometry(2,5,100,6),mkMat(0x080825,pc,0.5));
    shaft.position.set(px,50,pz);threeScene.add(shaft);
    const cap=new THREE.Mesh(new THREE.SphereGeometry(6,8,8),mkBasic(pc));
    cap.position.set(px,105,pz);threeScene.add(cap);
    const ring=new THREE.Mesh(new THREE.TorusGeometry(8,1.2,6,20),mkBasic(pc));
    ring.position.set(px,55,pz);ring.rotation.x=Math.PI/2;threeScene.add(ring);
    const pl=new THREE.PointLight(pc,4,300);pl.position.set(px,108,pz);threeScene.add(pl);
    threeLights.push({light:pl,phase:Math.random()*Math.PI*2,ring,cap});
  });

  // ── CRYSTALS: 20, rotated each frame but only redrawn by Three ──
  for(let i=0;i<22;i++){
    const cc=bColors[Math.floor(Math.random()*bColors.length)];
    const geos=[
      new THREE.OctahedronGeometry(3+Math.random()*9,0),
      new THREE.TetrahedronGeometry(4+Math.random()*8,0),
      new THREE.IcosahedronGeometry(3+Math.random()*7,0),
    ];
    const wire=Math.random()>.45;
    const mat=wire?new THREE.MeshBasicMaterial({color:cc,wireframe:true}):mkMat(0,cc,0.7);
    const crystal=new THREE.Mesh(geos[Math.floor(Math.random()*geos.length)],mat);
    const ang=Math.random()*Math.PI*2,rad=70+Math.random()*400;
    crystal.position.set(Math.cos(ang)*rad,10+Math.random()*45,Math.sin(ang)*rad);
    crystal._rX=(Math.random()-.5)*.022;crystal._rY=(Math.random()-.5)*.032;
    crystal._bobPhase=Math.random()*Math.PI*2;crystal._baseY=crystal.position.y;
    threeScene.add(crystal);
    threeCrystals.push(crystal);
  }

  // ── HOLO TOWERS: 4 only ──
  [[-220,0,-220],[220,0,-220],[-220,0,220],[220,0,220]].forEach(([hx,_hy,hz],hi)=>{
    const hc=bColors[hi*2%bColors.length];
    const spire=new THREE.Mesh(new THREE.CylinderGeometry(1,3,70,6),mkMat(0x020210,hc,0.7));
    spire.position.set(hx,35,hz);threeScene.add(spire);
    const rings=[];
    for(let r=0;r<2;r++){
      const rm=new THREE.Mesh(new THREE.TorusGeometry(10+r*5,1,6,20),mkBasic(hc));
      rm.position.set(hx,18+r*24,hz);threeScene.add(rm);rings.push(rm);
    }
    const diam=new THREE.Mesh(new THREE.OctahedronGeometry(7,0),mkMat(hc,hc,2));
    diam.position.set(hx,76,hz);threeScene.add(diam);
    const hl=new THREE.PointLight(hc,2.5,180);hl.position.set(hx,78,hz);threeScene.add(hl);
    threeHoloTowers.push({rings,diam,col:hc,phase:hi*Math.PI*.5,light:hl});
  });

  // ── PORTALS: 4, simple torus arches ──
  [[-460,0,0],[460,0,0],[0,0,-460],[0,0,460]].forEach(([px,_py,pz],pi)=>{
    const pc=pillarCols[pi*2%8];
    const arch=new THREE.Mesh(new THREE.TorusGeometry(32,2.5,8,24,Math.PI),mkBasic(pc));
    arch.position.set(px,32,pz);if(px===0)arch.rotation.y=Math.PI/2;
    threeScene.add(arch);
    const pl=new THREE.PointLight(pc,3,220);pl.position.set(px,34,pz);threeScene.add(pl);
    threePortals.push({arch,col:pc,phase:pi*Math.PI*.5,light:pl});
  });

  // ── SPACESHIPS: 3 ──
  for(let i=0;i<3;i++){
    const sc=bColors[Math.floor(Math.random()*bColors.length)];
    const grp=new THREE.Group();
    const _hull=new THREE.Mesh(new THREE.CylinderGeometry(2,4,18,6),mkMat(0x111122,sc,0.4));_hull.rotation.z=Math.PI/2;grp.add(_hull);
    [-1,1].forEach(side=>{
      const wing=new THREE.Mesh(new THREE.BoxGeometry(10,0.8,5),mkMat(0x0a0a20,sc,0.3));
      wing.position.set(0,0,side*6);grp.add(wing);
    });
    const ang=Math.random()*Math.PI*2,rad=650+Math.random()*350;
    grp.position.set(Math.cos(ang)*rad,90+Math.random()*80,Math.sin(ang)*rad);
    grp._orbitRad=rad;grp._orbitAng=ang;grp._orbitSpeed=(Math.random()>.5?.002:-.002);grp._bobPhase=Math.random()*Math.PI*2;
    threeScene.add(grp);threeSpaceships.push(grp);
  }

  // ── RAIN: 1 layer only, 3000 points ──
  const rainPos=new Float32Array(3000*3);
  for(let i=0;i<3000;i++){rainPos[i*3]=(Math.random()-.5)*2400;rainPos[i*3+1]=Math.random()*380;rainPos[i*3+2]=(Math.random()-.5)*2400;}
  const rainGeo=new THREE.BufferGeometry();rainGeo.setAttribute('position',new THREE.BufferAttribute(rainPos,3));
  threeRain=new THREE.Points(rainGeo,new THREE.PointsMaterial({color:0x5577bb,size:0.7,transparent:true,opacity:0.22}));
  threeScene.add(threeRain);

  // ── ARENA RINGS: 2 only ──
  [492,508].forEach((r,i)=>{
    const ring=new THREE.Mesh(new THREE.RingGeometry(r,r+2,64),new THREE.MeshBasicMaterial({color:[0x00f0ff,0x0066ff][i],transparent:true,opacity:[0.6,0.2][i],side:THREE.DoubleSide}));
    ring.rotation.x=-Math.PI/2;ring.position.y=2+i*4;threeScene.add(ring);
  });

  // ── STARS: 800 points ──
  const starPos=new Float32Array(800*3);
  for(let i=0;i<800;i++){
