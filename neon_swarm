// ── CAMERA ──
function updateCamera(){
  if(!player)return;
  zoomLevel+=(targetZoom-zoomLevel)*.1;
  const vw=W/zoomLevel,vh=H/zoomLevel; // effective world-space viewport size at current zoom
  camX+=(player.x-vw/2-camX)*.11;camY+=(player.y-vh/2-camY)*.11;
  camX=Math.max(0,Math.min(WORLD-vw,camX));camY=Math.max(0,Math.min(WORLD-vh,camY));
  if(shakeAmt>0){camX+=(Math.random()-.5)*shakeAmt;camY+=(Math.random()-.5)*shakeAmt;shakeAmt*=.77;if(shakeAmt<.2)shakeAmt=0;}
}

// ── 2D BACKGROUND ──
function buildBG2D(){
  bgCanvas2d=document.createElement('canvas');bgCanvas2d.width=WORLD;bgCanvas2d.height=WORLD;
  bgCtx2d=bgCanvas2d.getContext('2d');const c=bgCtx2d;
  c.clearRect(0,0,WORLD,WORLD);
  c.strokeStyle='rgba(0,120,200,0.055)';c.lineWidth=1;
  for(let x=0;x<WORLD;x+=72){c.beginPath();c.moveTo(x,0);c.lineTo(x,WORLD);c.stroke();}
  for(let y=0;y<WORLD;y+=72){c.beginPath();c.moveTo(0,y);c.lineTo(WORLD,y);c.stroke();}
  ['#00f0ff','#ff00aa','#bf00ff','#ff8800','#00ffaa'].forEach(col=>{
    for(let i=0;i<5;i++){
      const px=Math.random()*WORLD,py=Math.random()*WORLD;
      const g=c.createRadialGradient(px,py,0,px,py,120+Math.random()*100);
      g.addColorStop(0,hexRgba(col,.12));g.addColorStop(1,'transparent');
      c.fillStyle=g;c.beginPath();c.ellipse(px,py,130,42,Math.random()*Math.PI,0,Math.PI*2);c.fill();
    }
  });
  c.strokeStyle='rgba(0,240,255,0.55)';c.lineWidth=6;c.strokeRect(20,20,WORLD-40,WORLD-40);
  c.strokeStyle='rgba(0,240,255,0.2)';c.lineWidth=2;c.strokeRect(12,12,WORLD-24,WORLD-24);
  [[20,20],[WORLD-20,20],[20,WORLD-20],[WORLD-20,WORLD-20]].forEach(([cx,cy])=>{
    const g=c.createRadialGradient(cx,cy,0,cx,cy,22);g.addColorStop(0,'rgba(0,240,255,0.9)');g.addColorStop(1,'transparent');
    c.fillStyle=g;c.beginPath();c.arc(cx,cy,22,0,Math.PI*2);c.fill();
    c.fillStyle='rgba(0,240,255,1)';c.beginPath();c.arc(cx,cy,5,0,Math.PI*2);c.fill();
  });
}

// ── MINIMAP ──
function drawMinimap(){
  const MM=84;
  mctx.clearRect(0,0,MM,MM);mctx.fillStyle='rgba(0,0,8,0.8)';mctx.fillRect(0,0,MM,MM);
  const sc=MM/WORLD;
  mctx.shadowColor='#00f0ff';mctx.shadowBlur=4;mctx.fillStyle='#00f0ff';
  mctx.beginPath();mctx.arc(player.x*sc,player.y*sc,2.5,0,Math.PI*2);mctx.fill();
  mctx.shadowBlur=0;
  enemies.forEach(e=>{if(!e.alive)return;mctx.fillStyle=e.type==='boss'?'#ff0055':e.color;mctx.beginPath();mctx.arc(e.x*sc,e.y*sc,e.type==='boss'?3.5:1.3,0,Math.PI*2);mctx.fill();});
  orbs.forEach(o=>{mctx.fillStyle='rgba(191,0,255,0.6)';mctx.fillRect(o.x*sc-.5,o.y*sc-.5,1.3,1.3);});
  mctx.strokeStyle='rgba(0,240,255,0.35)';mctx.lineWidth=1;mctx.strokeRect(0,0,MM,MM);
  mctx.fillStyle='rgba(0,240,255,0.5)';mctx.font='7px Courier New';mctx.fillText('W'+wave+'/'+maxWaves,2,9);
}

// ── DRAW PLAYER ──
function drawPlayer(){
  const x=player.x-camX,y=player.y-camY;
  ctx.save();ctx.translate(x,y);ctx.rotate(player.facing);
  const t=Date.now()*.003,inv=player.invTimer>0&&Math.floor(player.invTimer*10)%2;
  if(!inv){
    const grad=ctx.createRadialGradient(0,0,10,0,0,45);grad.addColorStop(0,'rgba(0,240,255,0.14)');grad.addColorStop(1,'transparent');
    ctx.fillStyle=grad;ctx.beginPath();ctx.arc(0,0,45,0,Math.PI*2);ctx.fill();
    ctx.shadowColor='#00f0ff';ctx.shadowBlur=28;
    ctx.strokeStyle='rgba(0,240,255,'+(0.18+Math.sin(t)*.08)+')';ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(0,0,30,0,Math.PI*2);ctx.stroke();
  }
  ctx.shadowColor='#00f0ff';ctx.shadowBlur=inv?5:20;
  ctx.fillStyle=inv?'rgba(255,255,255,0.4)':'#0d0520';
  ctx.beginPath();ctx.moveTo(26,0);ctx.lineTo(-17,-17);ctx.lineTo(-11,0);ctx.lineTo(-17,17);ctx.closePath();ctx.fill();
  ctx.strokeStyle=inv?'#fff':'#00f0ff';ctx.lineWidth=2;ctx.stroke();
  if(!inv){
    const bg=ctx.createLinearGradient(-17,-17,26,0);bg.addColorStop(0,'rgba(0,240,255,0.25)');bg.addColorStop(1,'transparent');
    ctx.fillStyle=bg;ctx.beginPath();ctx.moveTo(26,0);ctx.lineTo(-17,-17);ctx.lineTo(-11,0);ctx.closePath();ctx.fill();
    ctx.fillStyle='#aa00cc';ctx.fillRect(-8,-10,14,7);ctx.fillRect(-8,3,14,7);
    ctx.fillStyle='#00f0ff';ctx.shadowBlur=14;ctx.fillRect(1,-3,9,6);
    ctx.fillStyle='rgba(0,255,255,0.4)';ctx.fillRect(1,-3,4,2);
