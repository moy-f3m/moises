    const hue=(t*30)%360;
    const g=ctx.createRadialGradient(0,0,0,0,0,b.size);
    g.addColorStop(0,'hsl('+(hue)+',100%,90%)');g.addColorStop(.3,'hsl('+((hue+120)%360)+',100%,60%)');g.addColorStop(.7,'hsl('+((hue+240)%360)+',100%,30%)');g.addColorStop(1,'rgba(0,0,0,1)');
    ctx.fillStyle=g;ctx.beginPath();ctx.arc(0,0,b.size,0,Math.PI*2);ctx.fill();
    for(let r=0;r<5;r++){ctx.strokeStyle='hsl('+((hue+r*60)%360)+',100%,70%)';ctx.lineWidth=3-r*.4;ctx.beginPath();ctx.arc(0,0,b.size*(.3+r*.16),0,Math.PI*2);ctx.stroke();}
    for(let i=0;i<20;i++){const oa=i/20*Math.PI*2+t*2;ctx.fillStyle='hsl('+((hue+i*18)%360)+',100%,80%)';ctx.shadowBlur=12;ctx.beginPath();ctx.arc(Math.cos(oa)*b.size*.75,Math.sin(oa)*b.size*.75,3,0,Math.PI*2);ctx.fill();}
    ctx.shadowBlur=80;ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(0,0,28,0,Math.PI*2);ctx.fill();ctx.fillStyle='#000';ctx.beginPath();ctx.arc(0,0,14,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='hsl('+(hue)+',100%,70%)';ctx.shadowBlur=20;ctx.beginPath();ctx.arc(8*Math.cos(t*3),8*Math.sin(t*3),8,0,Math.PI*2);ctx.fill();
  }
  const hpPct=Math.max(0,b.hp/b.maxHp);
  ctx.globalAlpha=1;ctx.shadowBlur=6;ctx.fillStyle='rgba(0,0,0,0.75)';ctx.fillRect(-b.size,-b.size-22,b.size*2,12);
  ctx.fillStyle=b.color;ctx.fillRect(-b.size,-b.size-22,b.size*2*hpPct,12);
  ctx.fillStyle='rgba(255,255,255,0.25)';ctx.fillRect(-b.size,-b.size-22,b.size*2*hpPct,4);
  ctx.fillStyle='#fff';ctx.shadowBlur=0;ctx.font='bold 9px Courier New';ctx.textAlign='center';
  ctx.fillText('PH'+b.phase+'★'.repeat(b.phase-1),0,-b.size-26);
}

// ── DRAW PROJECTILES, MISSILES, ORBS, PARTICLES, LIGHTNING ──
function drawProjectiles(){
  ctx.save();
  // Pass 1: trails (no shadow)
  ctx.lineCap='round';
  projectiles.forEach(p=>{
    if(!p.trail||p.trail.length<2)return;
    const x=p.x-camX,y=p.y-camY;if(x<-40||x>W/zoomLevel+40||y<-40||y>H/zoomLevel+40)return;
    const alpha=p.life/p.maxLife;
    ctx.globalAlpha=alpha*.4;ctx.strokeStyle=p.color;ctx.lineWidth=p.size*.7;ctx.beginPath();
    ctx.moveTo(p.trail[0].x-camX,p.trail[0].y-camY);
    for(let i=1;i<p.trail.length;i++)ctx.lineTo(p.trail[i].x-camX,p.trail[i].y-camY);
    ctx.lineTo(x,y);ctx.stroke();
  });
  // Pass 2: cores (shadow only on glow projectiles)
  projectiles.forEach(p=>{
    const x=p.x-camX,y=p.y-camY;if(x<-40||x>W/zoomLevel+40||y<-40||y>H/zoomLevel+40)return;
    const alpha=p.life/p.maxLife;
    ctx.globalAlpha=Math.min(1,alpha*2.5);
    if(p.glow){ctx.shadowColor=p.color;ctx.shadowBlur=18;}
    else{ctx.shadowBlur=0;}
    ctx.fillStyle=p.color;ctx.beginPath();ctx.arc(x,y,p.size,0,Math.PI*2);ctx.fill();
    // White core dot (cheap, no gradient)
    ctx.globalAlpha=Math.min(1,alpha*3);ctx.fillStyle='rgba(255,255,255,0.8)';ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(x,y,p.size*.32,0,Math.PI*2);ctx.fill();
  });
  ctx.restore();
}
function drawMissiles(){
  missiles.forEach(m=>{
    const x=m.x-camX,y=m.y-camY;ctx.save();ctx.translate(x,y);ctx.rotate(Math.atan2(m.vy,m.vx));
    ctx.shadowColor=m.color;ctx.shadowBlur=22;
    const mg=ctx.createLinearGradient(-8,0,12,0);mg.addColorStop(0,'rgba(255,220,0,.9)');mg.addColorStop(.4,m.color);mg.addColorStop(1,hexRgba(m.color,.5));
    ctx.fillStyle=mg;ctx.beginPath();ctx.moveTo(12,0);ctx.lineTo(-8,-5);ctx.lineTo(-8,5);ctx.closePath();ctx.fill();
    ctx.fillStyle='rgba(255,230,80,.9)';ctx.beginPath();ctx.moveTo(-8,0);ctx.lineTo(-16,-3);ctx.lineTo(-16,3);ctx.closePath();ctx.fill();
    ctx.restore();
  });
}
function drawOrbs(){
  const t=Date.now()*.004;
  ctx.save();
  orbs.forEach(o=>{
    const x=o.x-camX,y=o.y-camY,bob=Math.sin(t*1.5+o.x*.01)*3;
    ctx.shadowColor=o.color;ctx.shadowBlur=10;
    ctx.fillStyle=o.color;ctx.beginPath();ctx.arc(x,y+bob,o.size,0,Math.PI*2);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.7)';ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(x-o.size*.28,y+bob-o.size*.28,o.size*.3,0,Math.PI*2);ctx.fill();
  });
  ctx.restore();
}
function drawParticles(){
  // Batch by color group to minimize state changes
  ctx.save();
  particles.forEach(p=>{
    const x=p.x-camX,y=p.y-camY;if(x<-20||x>W/zoomLevel+20||y<-20||y>H/zoomLevel+20)return;
    const alpha=p.life/p.maxLife;
    ctx.globalAlpha=alpha;ctx.fillStyle=p.color;
    ctx.beginPath();ctx.arc(x,y,Math.max(.4,p.size*alpha),0,Math.PI*2);ctx.fill();
  });
  ctx.restore();
}
function drawLightnings(){
  lightnings.forEach(l=>{
    ctx.save();ctx.globalAlpha=l.life/.14;ctx.strokeStyle='#ccffff';ctx.shadowColor='#00f0ff';ctx.shadowBlur=25;ctx.lineWidth=2+Math.random()*3;
    ctx.beginPath();ctx.moveTo(l.x1-camX,l.y1-camY);
    for(let i=1;i<=10;i++) ctx.lineTo(l.x1+(l.x2-l.x1)*i/10-camX+(Math.random()-.5)*35,l.y1+(l.y2-l.y1)*i/10-camY+(Math.random()-.5)*35);
    ctx.stroke();ctx.restore();
  });
}
function drawDmgNumbers(){
  dmgNumbers.forEach(d=>{ctx.save();ctx.globalAlpha=d.life;ctx.font='bold '+d.size+'px Courier New';ctx.fillStyle=d.color;ctx.shadowColor=d.color;ctx.shadowBlur=10;ctx.textAlign='center';ctx.fillText(d.text,d.sx,d.sy);ctx.restore();});
}
function drawRain(){
  const t=Date.now(),vw=W/zoomLevel,vh=H/zoomLevel;ctx.save();ctx.strokeStyle='#7799cc';ctx.lineWidth=.7/zoomLevel;
  for(let i=0;i<120;i++){ctx.globalAlpha=.04+Math.sin(i*.7+t*.001)*.02;const rx=(Math.sin(i*997+t*.00044)*vw*2+t*.19)%vw,ry=(i*53+t*.33)%vh;ctx.beginPath();ctx.moveTo(rx,ry);ctx.lineTo(rx+5,ry+20);ctx.stroke();}
  ctx.globalAlpha=1;ctx.restore();
}

// ── MAIN LOOP ──
let lastTime=0;
function loop(ts){
  const dt=Math.min((ts-lastTime)/1000,.05);lastTime=ts;
  requestAnimationFrame(loop);
  if(!gameRunning)return;
  if(player){if(isMobileDevice)autoAim();updatePlayer(dt);updateShooting(dt);}
  updateProjectiles(dt);updateMissiles(dt);updateEnemies(dt);
  updateOrbs(dt);updateParticles(dt);updateDmgNumbers(dt);updateLightnings(dt);updateCamera();
  updateThree(player?player.x:WORLD/2,player?player.y:WORLD/2,bossAlive,wave);
  ctx.clearRect(0,0,W,H);
  ctx.save();
  ctx.scale(zoomLevel,zoomLevel);
  if(bgCanvas2d)ctx.drawImage(bgCanvas2d,-camX,-camY);
  if(lightningFlash>0){ctx.fillStyle='rgba(0,160,255,'+lightningFlash*.1+')';ctx.fillRect(0,0,W/zoomLevel,H/zoomLevel);lightningFlash-=.025;}
  drawRain();drawOrbs();drawParticles();drawProjectiles();drawMissiles();
  drawEnemies();drawLightnings();
  if(player&&player.alive)drawPlayer();
  drawDmgNumbers();
  ctx.restore();
  drawMinimap();
}

// ── VIRTUAL JOYSTICK & MOBILE INPUT ──
const joystickState={active:false,id:-1,startX:0,startY:0,dx:0,dy:0,radius:65};

let _mobileControlsInitialized=false;
function initMobileControls(){
  if(_mobileControlsInitialized)return;
  _mobileControlsInitialized=true;
  const zone=document.getElementById('joystick-zone');
  if(!zone)return;

  // Prevent default touch behavior on game canvas
  document.getElementById('c').addEventListener('touchstart',e=>e.preventDefault(),{passive:false});
  document.getElementById('c').addEventListener('touchmove',e=>e.preventDefault(),{passive:false});
  document.getElementById('three-bg').addEventListener('touchstart',e=>e.preventDefault(),{passive:false});

  // Joystick touch start
  zone.addEventListener('touchstart',e=>{
    e.preventDefault();
    const t=e.changedTouches[0];
    const rect=zone.getBoundingClientRect();
    joystickState.active=true;
    joystickState.id=t.identifier;
    joystickState.startX=rect.left+rect.width/2;
    joystickState.startY=rect.top+rect.height/2;
    updateJoystick(t.clientX,t.clientY);
  },{passive:false});

  zone.addEventListener('touchmove',e=>{
    e.preventDefault();
    for(let i=0;i<e.changedTouches.length;i++){
      if(e.changedTouches[i].identifier===joystickState.id){
        updateJoystick(e.changedTouches[i].clientX,e.changedTouches[i].clientY);break;
      }
    }
  },{passive:false});

  function endJoystick(e){
    e.preventDefault();
    for(let i=0;i<e.changedTouches.length;i++){
      if(e.changedTouches[i].identifier===joystickState.id){
        joystickState.active=false;joystickState.dx=0;joystickState.dy=0;
        const knob=document.getElementById('joystick-knob');
        if(knob){knob.style.transform='translate(-50%,-50%)';}
        break;
      }
    }
  }
  zone.addEventListener('touchend',endJoystick,{passive:false});
  zone.addEventListener('touchcancel',endJoystick,{passive:false});
}

function updateJoystick(cx,cy){
  const dx=cx-joystickState.startX,dy=cy-joystickState.startY;
  const dist=Math.sqrt(dx*dx+dy*dy);
  const maxR=joystickState.radius;
  const clampedDist=Math.min(dist,maxR);
  const angle=Math.atan2(dy,dx);
  joystickState.dx=Math.cos(angle)*(clampedDist/maxR);
  joystickState.dy=Math.sin(angle)*(clampedDist/maxR);
  // Move knob visually
  const knob=document.getElementById('joystick-knob');
  if(knob){
    const kx=Math.cos(angle)*Math.min(dist,maxR*.7);
    const ky=Math.sin(angle)*Math.min(dist,maxR*.7);
    knob.style.transform=`translate(calc(-50% + ${kx}px), calc(-50% + ${ky}px))`;
  }
}

function getMobileInput(){
  if(joystickState.active){
    return {dx:joystickState.dx,dy:joystickState.dy};
  }
  return {dx:0,dy:0};
}

// Auto-aim: find nearest enemy and face toward it
function autoAim(){
  if(!player||!enemies.length)return;
  let best=null,bestDist=99999;
  enemies.forEach(e=>{
    if(!e.alive)return;
    const d=Math.hypot(e.x-player.x,e.y-player.y);
    if(d<bestDist){bestDist=d;best=e;}
  });
  if(best){
    player.facing=Math.atan2(best.y-player.y,best.x-player.x);
    // Also update mouse position for compatibility
    mouse.x=(best.x-camX);mouse.y=(best.y-camY);
  }
}


// ── INPUT ──
document.addEventListener('keydown',e=>{
  keys[e.code]=true;
  if(gameRunning){
    if(e.code==='KeyQ')castSkill(0);if(e.code==='KeyF')castSkill(1);
    if(e.code==='KeyE')castSkill(2);if(e.code==='KeyR')castSkill(3);
  }
  e.preventDefault();
});
document.addEventListener('keyup',e=>keys[e.code]=false);
document.addEventListener('mousemove',e=>{mouse.x=e.clientX;mouse.y=e.clientY;});
document.addEventListener('contextmenu',e=>e.preventDefault());

// ── ZOOM: mouse wheel (desktop) ──
document.addEventListener('wheel',e=>{
  e.preventDefault();
  targetZoom=Math.max(MIN_ZOOM,Math.min(MAX_ZOOM,targetZoom-e.deltaY*0.001));
},{passive:false});

// ── ZOOM: pinch-to-zoom (touch) ──
let _pinchStartDist=0,_pinchStartZoom=1;
function _touchDist(t1,t2){return Math.hypot(t1.clientX-t2.clientX,t1.clientY-t2.clientY);}
document.addEventListener('touchstart',e=>{
  if(e.touches.length===2){
    _pinchStartDist=_touchDist(e.touches[0],e.touches[1]);
    _pinchStartZoom=targetZoom;
  }
},{passive:true});
document.addEventListener('touchmove',e=>{
  if(e.touches.length===2){
    e.preventDefault();
    const dist=_touchDist(e.touches[0],e.touches[1]);
    if(_pinchStartDist>0){
      const ratio=dist/_pinchStartDist;
      targetZoom=Math.max(MIN_ZOOM,Math.min(MAX_ZOOM,_pinchStartZoom*ratio));
    }
  }
},{passive:false});

// ── GAME FLOW ──
function startGame(){
  initAudio();initThree();initMobileControls();
  document.getElementById('overlay').style.display='none';
  buildBG2D();initGame();gameRunning=true;startBGM(0);
  requestAnimationFrame(loop);
}

function endGame(won){
  gameRunning=false;stopBGM();
  const ov=document.getElementById('overlay'),title=document.getElementById('overlay-title');
  const sub=document.getElementById('overlay-sub'),sub2=document.getElementById('overlay-sub2'),btn=document.getElementById('overlay-btn');
  if(won){
    title.style.color='#fff';title.style.textShadow='0 0 30px #fff,0 0 60px #00f0ff,0 0 100px #bf00ff';
    title.textContent='VICTORY';sub.textContent='THE SINGULARITY IS CONSUMED';
    sub2.innerHTML='SCORE: '+score+' | KILLS: '+kills+' | LEVEL: '+player.level+'<br>ALL 30 WAVES CLEARED · OMEGA SINGULARITY DEFEATED';
    btn.style.color='#00f0ff';btn.style.textShadow='0 0 12px #00f0ff';
  } else {
    title.style.color='#ff0055';title.style.textShadow='0 0 30px #ff0055,0 0 70px #ff0055';
    title.textContent='FLATLINED';sub.textContent='THE CITY CONSUMES YOU';
    sub2.innerHTML='SCORE: '+score+' | KILLS: '+kills+' | WAVE: '+wave+'/'+maxWaves+' | LEVEL: '+player.level;
    btn.style.color='#ff0055';btn.style.textShadow='0 0 12px #ff0055';
  }
  btn.textContent='► NEW RUN';ov.style.display='flex';
}

requestAnimationFrame(loop);
