function nextWave(){
  if(wave>=maxWaves)return;wave++;
  const tier=Math.min(Math.floor((wave-1)/5),5);startBGM(tier);
  const isBoss=BOSS_WAVES.includes(wave);
  const msgs=['SURVIVE THE NIGHT','HOLD THE LINE!','THEY KEEP COMING!','NO MERCY!','FIGHT OR DIE!','LAST STAND!'];
  if(isBoss){
    const bIdx=BOSS_WAVES.indexOf(wave);
    showAnnounce('WAVE '+wave,'⚠ BOSS INCOMING ⚠',3000);
    sfxWave();setTimeout(spawnWave,3000);
  } else {
    showAnnounce('WAVE '+wave,msgs[Math.min(tier,5)],2000);sfxWave();setTimeout(spawnWave,1600);
  }
}

// ── PARTICLES ──
function spawnBurst(x,y,c,color){if(particles.length>280)return;for(let i=0;i<c;i++){const a=Math.random()*Math.PI*2,s=75+Math.random()*170;particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,life:.45+Math.random()*.55,maxLife:.95,size:2+Math.random()*4,color});}}
function spawnImpact(x,y,color){if(particles.length>280)return;for(let i=0;i<8;i++){const a=Math.random()*Math.PI*2,s=100+Math.random()*130;particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,life:.18+Math.random()*.18,maxLife:.36,size:2+Math.random()*3,color});}}
function updateParticles(dt){for(let i=particles.length-1;i>=0;i--){const p=particles[i];p.x+=p.vx*dt;p.y+=p.vy*dt;p.vx*=.87;p.vy*=.87;p.life-=dt;if(p.life<=0)particles.splice(i,1);}}
function showFloating(text,sx,sy,color,size=12){dmgNumbers.push({text:String(text),sx,sy,vy:-70,life:1,color,size});}
function updateDmgNumbers(dt){for(let i=dmgNumbers.length-1;i>=0;i--){const d=dmgNumbers[i];d.sy+=d.vy*dt;d.vy*=.86;d.life-=dt;if(d.life<=0)dmgNumbers.splice(i,1);}}

function updateHUD(){
  document.getElementById('hp-fill').style.width=(player.hp/player.maxHp*100)+'%';
  document.getElementById('mp-fill').style.width=(player.mp/player.maxMp*100)+'%';
  document.getElementById('xp-fill').style.width=(player.xp/player.xpNext*100)+'%';
  document.getElementById('level-txt').textContent='LVL '+player.level+' — '+Math.floor(player.xp)+' / '+player.xpNext+' XP';
  document.getElementById('score-txt').textContent='SCORE: '+score;
  document.getElementById('kills-txt').textContent='KILLS: '+kills;
}
function updateSkillUI(){for(let i=0;i<4;i++){const el=document.getElementById('sk'+i+'-cd');if(el)el.style.height=Math.max(0,skillCooldowns[i]/skillMaxCd[i]*100)+'%';}}
function showAnnounce(main,sub,dur){
  const wa=document.getElementById('wave-announce'),sa=document.getElementById('sub-announce');
  wa.textContent=main;sa.textContent=sub;wa.style.opacity=1;sa.style.opacity=1;
