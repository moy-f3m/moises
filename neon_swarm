    {icon:'💧',name:'MAX MANA +45',fn:()=>{player.maxMp+=45;player.mp=Math.min(player.mp+45,player.maxMp);}},
    {icon:'⚡',name:'DAMAGE +22%',fn:()=>{player.dmg*=1.22;}},
    {icon:'👟',name:'SPEED +22%',fn:()=>{player.speed*=1.22;}},
    {icon:'🔥',name:'FIRE RATE +25%',fn:()=>{shootRate*=.78;}},
    {icon:'🧬',name:'MANA REGEN +65%',fn:()=>{player.mpRegen*=1.65;}},
    {icon:'💎',name:'FULL RESTORE',fn:()=>{player.hp=player.maxHp;player.mp=player.maxMp;}},
    {icon:'🌀',name:'SKILL HASTE +32%',fn:()=>{skillMaxCd=skillMaxCd.map(c=>c*.68);}},
    {icon:'🎯',name:'MULTISHOT',fn:()=>{player.extraShots=(player.extraShots||0)+1;player.dmg*=1.08;}},
    {icon:'🛡️',name:'ARMOR +60',fn:()=>{player.armor=(player.armor||0)+60;}},
    {icon:'💥',name:'CRIT +8%',fn:()=>{player.critBoost=(player.critBoost||0)+.08;}},
    {icon:'⚗️',name:'MANA LEECH',fn:()=>{player.manaLeech=true;}},
  ];
  const choices=document.getElementById('upgrade-choices');choices.innerHTML='';
  opts.sort(()=>Math.random()-.5).slice(0,3).forEach(o=>{
