// ── ENEMY AI ──
function updateEnemies(dt){
  enemies.forEach(e=>{
    if(!e.alive)return;
    if(e.flashTimer>0)e.flashTimer-=dt;
    const dx=player.x-e.x,dy=player.y-e.y,dist=Math.sqrt(dx*dx+dy*dy)||1,nx=dx/dist,ny=dy/dist;
    if(e.type==='boss'){updateBoss(e,dt,nx,ny,dist);return;}
    const af=1-(player.armor||0)/600;
    switch(e.type){
      case 'soldier':e.vx=nx*e.speed;e.vy=ny*e.speed;break;
      case 'drone':
        e.vx=dist>160?nx*e.speed:-nx*e.speed*.5;e.vy=dist>160?ny*e.speed:-ny*e.speed*.5;
        if((e.shootTimer-=dt)<=0){e.shootTimer=e.shootRate;projectiles.push({x:e.x,y:e.y,vx:nx*315,vy:ny*315,dmg:e.dmg,life:1.4,maxLife:1.4,size:6,type:'enemy',color:e.color,trail:[]});}break;
      case 'spider':
        e.vx=nx*e.speed;e.vy=ny*e.speed;
        if((e.aoeTimer-=dt)<=0&&dist<230){e.aoeTimer=e.aoeRate;for(let i=0;i<10;i++){const a=i/10*Math.PI*2;projectiles.push({x:e.x,y:e.y,vx:Math.cos(a)*220,vy:Math.sin(a)*220,dmg:e.dmg*.55,life:1.1,maxLife:1.1,size:5,type:'enemy',color:e.color,trail:[]});}spawnBurst(e.x,e.y,9,e.color);}break;
      case 'specter':
        if((e.dashTimer-=dt)<=0){e.dashTimer=e.dashRate;e.vx=nx*e.speed*2.8;e.vy=ny*e.speed*2.8;spawnBurst(e.x,e.y,8,e.color);}
        else{e.vx+=(nx*e.speed-e.vx)*dt*3;e.vy+=(ny*e.speed-e.vy)*dt*3;}
        e.alpha=.2+Math.sin(Date.now()*.005+e.id*10)*.3;break;
      case 'tank':
        e.vx=nx*e.speed;e.vy=ny*e.speed;
        if((e.shootTimer-=dt)<=0){e.shootTimer=e.shootRate;for(let i=0;i<6;i++){const a=Math.atan2(dy,dx)+(i-2.5)*.26;projectiles.push({x:e.x,y:e.y,vx:Math.cos(a)*250,vy:Math.sin(a)*250,dmg:e.dmg,life:1.8,maxLife:1.8,size:9,type:'enemy',color:e.color,glow:true,trail:[]});}shakeAmt=Math.max(shakeAmt,4);}break;
      case 'reaper':
        if((e.teleTimer-=dt)<=0&&dist>70){e.teleTimer=e.teleRate;const ta=Math.atan2(dy,dx)+(Math.random()-.5)*.6;e.x=player.x-Math.cos(ta)*75;e.y=player.y-Math.sin(ta)*75;spawnBurst(e.x,e.y,14,e.color);lightnings.push({x1:e.x,y1:e.y,x2:player.x,y2:player.y,life:.14,dmg:e.dmg*.5});}
        e.vx=nx*e.speed;e.vy=ny*e.speed;break;
      case 'swarm':e.vx=nx*e.speed;e.vy=ny*e.speed;break;
      case 'siege':
        e.vx=nx*e.speed;e.vy=ny*e.speed;
        if((e.shootTimer-=dt)<=0){e.shootTimer=e.shootRate;const base=Math.atan2(dy,dx);for(let i=0;i<8;i++){const a=base+(i-3.5)*.22;projectiles.push({x:e.x,y:e.y,vx:Math.cos(a)*230,vy:Math.sin(a)*230,dmg:e.dmg,life:2,maxLife:2,size:10,type:'enemy',color:e.color,glow:true,trail:[]});}shakeAmt=Math.max(shakeAmt,6);}break;
      case 'mage':
        e.vx+=(nx*e.speed-e.vx)*dt*2;e.vy+=(ny*e.speed-e.vy)*dt*2;
        if((e.shootTimer-=dt)<=0){e.shootTimer=e.shootRate;for(let i=0;i<3;i++){const a=Math.atan2(dy,dx)+(i-1)*.3;missiles.push({x:e.x,y:e.y,vx:Math.cos(a)*200,vy:Math.sin(a)*200,dmg:e.dmg,life:3,size:8,color:e.color,target:player,isEnemy:true});}}
        if((e.teleTimer-=dt)<=0){e.teleTimer=e.teleRate;const ang=Math.random()*Math.PI*2,r=150+Math.random()*200;e.x=player.x+Math.cos(ang)*r;e.y=player.y+Math.sin(ang)*r;spawnBurst(e.x,e.y,12,e.color);}break;
    }
    e.x+=e.vx*dt;e.y+=e.vy*dt;
    if(dist<e.size+20&&player.invTimer<=0){damagePlayer(e.dmg*af);player.invTimer=.5;}
  });
}

function updateBoss(b,dt,nx,ny,dist){
  b.phaseTimer+=dt;b.orbitAngle+=dt*(.4+b.phase*.28);
  if(b.hp<b.maxHp*.2&&b.phase<4)     {b.phase=4;lightningFlash=1;}
  else if(b.hp<b.maxHp*.4&&b.phase<3){b.phase=3;lightningFlash=.7;}
  else if(b.hp<b.maxHp*.65&&b.phase<2){b.phase=2;lightningFlash=.4;}
  b.vx=nx*b.speed*(1+b.phase*.32);b.vy=ny*b.speed*(1+b.phase*.32);
  b.x+=b.vx*dt;b.y+=b.vy*dt;
  b.shootTimer-=dt;
  if(b.shootTimer<=0){
    b.shootTimer=b.shootRate/(1+b.phase*.38);
    const cnt=b.burstCount+b.phase*3;
    for(let i=0;i<cnt;i++){const a=Math.atan2(player.y-b.y,player.x-b.x)+(i-(cnt-1)/2)*.24;projectiles.push({x:b.x,y:b.y,vx:Math.cos(a)*345,vy:Math.sin(a)*345,dmg:b.dmg,life:2.3,maxLife:2.3,size:11,type:'enemy',color:b.color,glow:true,trail:[]});}
    if(b.phase>=2) for(let i=0;i<16;i++){const a=i/16*Math.PI*2+b.orbitAngle;projectiles.push({x:b.x,y:b.y,vx:Math.cos(a)*210,vy:Math.sin(a)*210,dmg:b.dmg*.45,life:2,maxLife:2,size:7,type:'enemy',color:b.color,trail:[]});}
    if(b.phase>=3) for(let i=0;i<8;i++){const a=i/8*Math.PI*2-b.orbitAngle;projectiles.push({x:b.x,y:b.y,vx:Math.cos(a)*140,vy:Math.sin(a)*140,dmg:b.dmg*.3,life:2.5,maxLife:2.5,size:5,type:'enemy',color:b.color,trail:[]});}
    shakeAmt=Math.max(shakeAmt,5);
  }
  b.dashTimer-=dt;
  if(b.dashTimer<=0&&dist>140){b.dashTimer=b.dashT*(1-b.phase*.18);b.vx+=nx*800;b.vy+=ny*800;shakeAmt=Math.max(shakeAmt,14);spawnBurst(b.x,b.y,30,b.color);}
  b.summonTimer-=dt;
  if(b.summonTimer<=0&&b.phase>=2){b.summonTimer=7-b.phase*1.5;for(let i=0;i<3+b.phase;i++)spawnEnemy(Math.floor(Math.random()*5));}
  if(b.phase>=3&&Math.random()<.02) lightnings.push({x1:b.x,y1:b.y,x2:player.x,y2:player.y,life:.13,dmg:b.dmg*.3});
  if(dist<b.size+22&&player.invTimer<=0){damagePlayer(b.dmg*1.7*(1-(player.armor||0)/600));player.invTimer=.65;shakeAmt=16;}
  document.getElementById('boss-hp-fill').style.width=Math.max(0,b.hp/b.maxHp)*100+'%';
}

// ── PROJECTILES & MISSILES ──
function updateProjectiles(dt){
  for(let i=projectiles.length-1;i>=0;i--){
    const p=projectiles[i];
    if(p.trail){p.trail.push({x:p.x,y:p.y});if(p.trail.length>5)p.trail.shift();}
    p.x+=p.vx*dt;p.y+=p.vy*dt;p.life-=dt;
    if(p.life<=0||p.x<-80||p.x>WORLD+80||p.y<-80||p.y>WORLD+80){projectiles.splice(i,1);continue;}
    if(p.type==='player'){
      for(let j=enemies.length-1;j>=0;j--){
        const e=enemies[j];if(!e.alive)continue;
        const ddx=p.x-e.x,ddy=p.y-e.y;
        if(ddx*ddx+ddy*ddy<(e.size+p.size)*(e.size+p.size)){hitEnemy(e,p.dmg);spawnImpact(p.x,p.y,p.color);projectiles.splice(i,1);break;}
      }
    } else {
      if(!player.alive||player.shieldActive)continue;
      const ddx=p.x-player.x,ddy=p.y-player.y;
      if(ddx*ddx+ddy*ddy<(23+p.size)*(23+p.size)){damagePlayer(p.dmg*(1-(player.armor||0)/600));player.invTimer=.15;spawnImpact(p.x,p.y,'#ff4488');projectiles.splice(i,1);}
    }
  }
}

function updateMissiles(dt){
  for(let i=missiles.length-1;i>=0;i--){
    const m=missiles[i];m.life-=dt;if(m.life<=0){missiles.splice(i,1);continue;}
    if(m.isEnemy){
      if(player.shieldActive){missiles.splice(i,1);continue;}
      const ddx=player.x-m.x,ddy=player.y-m.y,d=Math.sqrt(ddx*ddx+ddy*ddy)||1;
      m.vx+=(ddx/d*460-m.vx)*dt*5;m.vy+=(ddy/d*460-m.vy)*dt*5;
      if(d<28){damagePlayer(m.dmg*(1-(player.armor||0)/600));spawnBurst(m.x,m.y,8,m.color);missiles.splice(i,1);continue;}
    } else {
      if(!m.target||!m.target.alive){let best=null,bd=9999;enemies.forEach(e=>{if(!e.alive)return;const d=Math.hypot(e.x-m.x,e.y-m.y);if(d<bd){bd=d;best=e;}});m.target=best;}
      if(m.target){
        const ddx=m.target.x-m.x,ddy=m.target.y-m.y,d=Math.sqrt(ddx*ddx+ddy*ddy)||1;
        m.vx+=(ddx/d*460-m.vx)*dt*5;m.vy+=(ddy/d*460-m.vy)*dt*5;
        if(d<m.target.size+12){hitEnemy(m.target,m.dmg);spawnBurst(m.x,m.y,12,m.color);missiles.splice(i,1);continue;}
      }
    }
    m.x+=m.vx*dt;m.y+=m.vy*dt;
    particles.push({x:m.x,y:m.y,vx:(Math.random()-.5)*55,vy:(Math.random()-.5)*55,life:.28,maxLife:.28,size:3,color:m.color});
  }
}

function updateLightnings(dt){
  for(let i=lightnings.length-1;i>=0;i--){
    const l=lightnings[i];l.life-=dt;if(l.life<=0){lightnings.splice(i,1);continue;}
    if(Math.hypot(l.x2-player.x,l.y2-player.y)<38&&player.invTimer<=0){damagePlayer(l.dmg*(1-(player.armor||0)/600));player.invTimer=.3;}
  }
}

function hitEnemy(e,dmg){
  if(!e.alive)return;
  const crit=Math.random()<.18+(player.critBoost||0);
  const actual=Math.round(dmg*(crit?2.2:1));
  e.hp-=actual;e.flashTimer=.1;sfxHit();if(crit)sfxCrit();
  showFloating(crit?'★'+actual:actual,e.x-camX,e.y-camY-e.size-5,crit?'#ffff00':'#fff',crit?16:12);
  if(player.manaLeech)player.mp=Math.min(player.maxMp,player.mp+actual*.04);
  if(e.hp<=0)killEnemy(e);
}

function killEnemy(e){
  e.alive=false;sfxDeath();score+=e.reward;kills++;
  spawnBurst(e.x,e.y,e.type==='boss'?60:24,e.color);shakeAmt=Math.max(shakeAmt,e.type==='boss'?20:6);
  const oc=e.type==='boss'?20:3;
  for(let i=0;i<oc;i++) orbs.push({x:e.x+(Math.random()-.5)*75,y:e.y+(Math.random()-.5)*75,val:Math.round(e.xpVal/oc),size:e.type==='boss'?13:6,color:e.type==='boss'?'#ffff00':'#bf00ff',vx:(Math.random()-.5)*140,vy:(Math.random()-.5)*140,life:10});
  if(e.type==='boss'){
    bossAlive=false;document.getElementById('boss-hpbar').style.display='none';stopBGM();sfxBossDefeat();lightningFlash=0;
    if(wave>=maxWaves){showAnnounce('VICTORY!','THE SINGULARITY IS YOURS',3400);setTimeout(()=>endGame(true),3800);}
    else{showAnnounce('BOSS SLAIN!','PREPARE FOR WAVE '+(wave+1),2600);setTimeout(()=>{waveClear=true;setTimeout(nextWave,1200);},1600);}
    return;
  }
  if(enemies.filter(x=>x.alive).length===0&&!waveClear&&!bossAlive) setTimeout(()=>{waveClear=true;setTimeout(nextWave,1800);},200);
}

function damagePlayer(dmg){
  if(!player.alive||player.shieldActive)return;
  player.hp-=Math.max(1,dmg);shakeAmt=Math.max(shakeAmt,9);spawnBurst(player.x,player.y,8,'#ff0066');
  if(player.hp<=0){player.hp=0;player.alive=false;setTimeout(()=>endGame(false),1700);}
  updateHUD();
}

// ── XP & LEVELING ──
function updateOrbs(dt){
  for(let i=orbs.length-1;i>=0;i--){
    const o=orbs[i];o.life-=dt;if(o.life<=0){orbs.splice(i,1);continue;}
    const ddx=player.x-o.x,ddy=player.y-o.y,d=Math.sqrt(ddx*ddx+ddy*ddy)||1;
    if(d<140){o.vx+=ddx/d*340*dt;o.vy+=ddy/d*340*dt;}
    o.vx*=.9;o.vy*=.9;o.x+=o.vx*dt;o.y+=o.vy*dt;
    if(d<22){player.xp+=o.val;score+=o.val;orbs.splice(i,1);while(player.xp>=player.xpNext)levelUp();updateHUD();}
  }
}
function levelUp(){
  player.xp-=player.xpNext;player.level++;player.xpNext=Math.round(player.xpNext*1.25);
  sfxLevelUp();showUpgradePanel();
}
function showUpgradePanel(){
