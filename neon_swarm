// ── PLAYER UPDATE ──
function updatePlayer(dt){
  if(!player.alive)return;
  let dx=0,dy=0;
  if(keys['KeyW']||keys['ArrowUp'])dy=-1;if(keys['KeyS']||keys['ArrowDown'])dy+=1;
  if(keys['KeyA']||keys['ArrowLeft'])dx-=1;if(keys['KeyD']||keys['ArrowRight'])dx+=1;
  if(dx&&dy){dx*=.707;dy*=.707;}
  // Blend in virtual joystick input (mobile)
  const jin=getMobileInput();
  if(jin.dx||jin.dy){dx=jin.dx;dy=jin.dy;}
  player.vx=dx*player.speed;player.vy=dy*player.speed;
  player.x=Math.max(30,Math.min(WORLD-30,player.x+player.vx*dt));
  player.y=Math.max(30,Math.min(WORLD-30,player.y+player.vy*dt));
  // Aim: mouse on desktop, auto-aim toward nearest enemy on mobile (handled in loop via autoAim())
  if(!isMobileDevice){
    player.facing=Math.atan2((mouse.y+camY)-player.y,(mouse.x+camX)-player.x);
  } else if(dx||dy){
    // No enemy nearby: face movement direction as fallback
    if(!enemies.some(e=>e.alive)) player.facing=Math.atan2(dy,dx);
  }
  player.mp=Math.min(player.maxMp,player.mp+player.mpRegen*dt);
  if(player.invTimer>0)player.invTimer-=dt;
  if(player.shieldActive){player.shieldTimer-=dt;if(player.shieldTimer<=0)player.shieldActive=false;}
  skillCooldowns=skillCooldowns.map(c=>Math.max(0,c-dt));
  updateSkillUI();updateHUD();
}

