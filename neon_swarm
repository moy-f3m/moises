    const a=base+(i-(2+spread)/2)*.16;
    projectiles.push({x:player.x,y:player.y,vx:Math.cos(a)*555,vy:Math.sin(a)*555,dmg:player.dmg,life:1.2,maxLife:1.2,size:5,type:'player',color:'#00f0ff',trail:[]});
